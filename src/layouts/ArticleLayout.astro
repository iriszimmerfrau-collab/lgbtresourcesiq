---
import BaseLayout from './BaseLayout.astro';
import SectionDivider from '@components/SectionDivider.astro';
import AnswerSummary from '@components/AnswerSummary.astro';
import type { Lang } from '@i18n/languages';
import { t } from '@i18n/utils';

interface RelatedLink {
  title: string;
  url: string;
}

interface ArticleMeta {
  publishedTime: string;
  modifiedTime?: string;
  section?: string;
  tags?: string[];
}

interface Props {
  title: string;
  description: string;
  lang: Lang;
  pubDate?: Date;
  updatedDate?: Date;
  readingTime?: number;
  jsonLd?: Record<string, unknown>;
  keywords?: string;
  /** Optional per-page og:image (e.g. /og-hrt.png). Defaults to BaseLayout default. */
  ogImage?: string;
  /** Optional article:* meta payload. */
  article?: ArticleMeta;
  /** Optional "See also" links rendered at the bottom of the article. */
  relatedLinks?: RelatedLink[];
  /**
   * Optional 1-3 sentence answer paragraph rendered above the slot inside an
   * AnswerSummary callout. Drives Speakable schema and front-loads AEO
   * extraction; sourced from collection frontmatter `tldr`.
   */
  tldr?: string;
}

const {
  title,
  description,
  lang,
  pubDate,
  updatedDate,
  readingTime,
  jsonLd,
  keywords,
  ogImage,
  article,
  relatedLinks,
  tldr,
} = Astro.props;

function formatDate(date: Date, locale: string): string {
  const tag = locale === 'ar' ? 'ar-IQ' : locale === 'ckb' ? 'ckb-IQ' : 'en-US';
  // ckb-IQ may not be supported in all runtimes; Intl falls through to a
  // reasonable best-match locale automatically.
  return date.toLocaleDateString(tag, {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  ogType="article"
  jsonLd={jsonLd}
  articleWidth
  keywords={keywords}
  ogImage={ogImage}
  article={article}
>
  <article class="prose">
    <header class="mb-8">
      <SectionDivider />
      <h1>{title}</h1>
      <div class="flex flex-wrap gap-4 text-sm text-muted mt-2">
        {pubDate && (
          <time datetime={pubDate.toISOString()}>
            {formatDate(pubDate, lang)}
          </time>
        )}
        {updatedDate && (
          <span>
            {t(lang, 'guides.lastUpdated')}: {formatDate(updatedDate, lang)}
          </span>
        )}
        {readingTime && (
          <span>{readingTime} {t(lang, 'guides.readTime')}</span>
        )}
      </div>
    </header>
    {tldr && <AnswerSummary text={tldr} lang={lang} />}
    <slot />

    {relatedLinks && relatedLinks.length > 0 && (
      <footer class="not-prose mt-12 pt-6 border-t-2 border-magenta/20">
        <h2 class="text-xs font-bold uppercase tracking-widest text-muted mb-3">
          {lang === 'ar' ? 'انظر أيضاً' : lang === 'ckb' ? 'هەروەها بڕوانە' : 'See also'}
        </h2>
        <ul class="list-none p-0 m-0 space-y-2">
          {relatedLinks.map((link) => (
            <li>
              <a
                href={link.url}
                class="text-navy hover:text-magenta font-semibold no-underline border-b border-magenta/30 hover:border-magenta transition-colors"
              >
                {link.title} →
              </a>
            </li>
          ))}
        </ul>
      </footer>
    )}
  </article>
</BaseLayout>

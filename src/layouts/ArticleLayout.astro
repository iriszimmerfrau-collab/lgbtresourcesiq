---
import BaseLayout from './BaseLayout.astro';
import SectionDivider from '@components/SectionDivider.astro';
import type { Lang } from '@i18n/languages';
import { t } from '@i18n/utils';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  pubDate?: Date;
  updatedDate?: Date;
  readingTime?: number;
  jsonLd?: Record<string, unknown>;
  keywords?: string;
}

const { title, description, lang, pubDate, updatedDate, readingTime, jsonLd, keywords } = Astro.props;

function formatDate(date: Date, locale: string): string {
  return date.toLocaleDateString(locale === 'ar' ? 'ar-IQ' : 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title={title} description={description} lang={lang} ogType="article" jsonLd={jsonLd} articleWidth keywords={keywords}>
  <article class="prose">
    <header class="mb-8">
      <SectionDivider />
      <h1>{title}</h1>
      <div class="flex flex-wrap gap-4 text-sm text-muted mt-2">
        {pubDate && (
          <time datetime={pubDate.toISOString()}>
            {formatDate(pubDate, lang)}
          </time>
        )}
        {updatedDate && (
          <span>
            {t(lang, 'guides.lastUpdated')}: {formatDate(updatedDate, lang)}
          </span>
        )}
        {readingTime && (
          <span>{readingTime} {t(lang, 'guides.readTime')}</span>
        )}
      </div>
    </header>
    <slot />
  </article>
</BaseLayout>

---
// Font CSS — @fontsource packages declare each @font-face with its own
// `unicode-range`, so even though all 16 face declarations land in one
// bundled CSS chunk, the browser only downloads the woff2 files for
// character ranges that actually appear on the rendered page. EN-only
// pages do not download the Arabic woff2 (~92KB); AR-only pages do not
// download the Latin/Latin-Ext woff2s. So shipping all faces to all
// pages is fine — the actual bytes are conditional via unicode-range.
import '@fontsource/libre-baskerville/400.css';
import '@fontsource/libre-baskerville/700.css';
import '@fontsource-variable/source-sans-3/index.css';
import '@fontsource-variable/noto-naskh-arabic/index.css';
import '@styles/global.css';

import type { Lang } from '@i18n/languages';
import { isRtl } from '@i18n/languages';
import QuickExit from '@components/QuickExit.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import PrivacyBanner from '@components/PrivacyBanner.astro';

interface ArticleMeta {
  publishedTime: string;
  modifiedTime?: string;
  section?: string;
  tags?: string[];
}

interface Props {
  title: string;
  description: string;
  lang: Lang;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
  articleWidth?: boolean;
  showBanner?: boolean;
  keywords?: string;
  /** Optional override for og:image. Defaults to /og-image.png. */
  ogImage?: string;
  /** Emitted as `article:*` meta tags when present. ArticleLayout populates this. */
  article?: ArticleMeta;
}

const {
  title,
  description,
  lang,
  ogType = 'website',
  jsonLd,
  articleWidth = false,
  showBanner = false,
  keywords,
  ogImage,
  article,
} = Astro.props;

const dir = isRtl(lang) ? 'rtl' : 'ltr';
const siteName = lang === 'ar' ? 'التجمع العراقي للتقدم الاجتماعي' : 'Iraqi Social Progress Collective';
const fullTitle = `${title} | ${siteName}`;
const currentPath = Astro.url.pathname;

const defaultKeywords = lang === 'ar'
  ? 'مثليين, مثلية, متحولين جنسياً, متحولات جنسياً, مزدوج الجنس, كوير, ميم عين, هوية جندرية, هوية جنسية, دعم نفسي, الصحة النفسية, اكتئاب, قلق, العراق, بغداد, البصرة, الموصل, أربيل, السليمانية, كردستان, كردستان العراق, علاج هرموني, هرمونات, إستروجين, تستوستيرون, سايبروترون, أندروكور, بيكالوتاميد, مذخر العراق, صيدلية هرمونات, جرائم الشرف, العنف الأسري, لجوء, VPN, خصوصية, حذف السجل, هل أنا مثلي, هل أنا متحول, كيف أعرف أني كوير, تقبّل الذات'
  : 'queer Iraq, LGBTQ Iraq, LGBT Iraq, gay Iraq, lesbian Iraq, trans Iraq, transgender Iraq, bisexual Iraq, queer Baghdad, queer Erbil, queer Basra, queer Mosul, queer Kurdistan, LGBT Kurdistan, Iraqi Kurdistan LGBT, HRT Iraq, hormones Iraq, estrogen Iraq, testosterone Iraq, cyproterone Iraq, Androcur Iraq, bicalutamide Iraq, spironolactone Iraq, where to buy hormones Iraq, Iraq pharmacy hormones, Iraq anti-LGBT law, Iraq Law 14 2024, Article 394 Iraq, queer asylum Iraq, Rainbow Railroad Iraq, gender identity, mental health Iraq, harm reduction Iraq, مثليين, متحولين, العراق, بغداد, كردستان, هرمونات, علاج هرموني, دعم نفسي, كوير, جرائم الشرف';

const canonicalUrl = new URL(currentPath, Astro.site).href;
const otherLang = lang === 'en' ? 'ar' : 'en';
// Anchored to the leading lang segment so substrings like "/menu/" or
// "/center/" inside future slugs don't get mangled.
const alternatePath = currentPath.replace(/^\/(en|ar)(\/|$)/, `/${otherLang}$2`);
const alternateUrl = new URL(alternatePath, Astro.site).href;
const ogImageUrl = new URL(ogImage ?? '/og-image.png', Astro.site).href;
const siteUrl = new URL('/', Astro.site).href;

const baseOrgGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}#org`,
      name: siteName,
      alternateName: lang === 'ar' ? 'Iraqi Social Progress Collective' : 'التجمع العراقي للتقدم الاجتماعي',
      url: siteUrl,
      logo: ogImageUrl,
      description: lang === 'ar'
        ? 'شبكة تكافلية شعبية للعراقيين الكويريين والمتسائلين داخل العراق. معلومات صحية، علاج هرموني، دعم نفسي، وأمان رقمي.'
        : 'A grassroots mutual aid network for queer Iraqis and questioning people inside Iraq. Health information, HRT access, mental health support, and digital safety.',
      areaServed: [
        { '@type': 'Country', name: 'Iraq' },
        { '@type': 'AdministrativeArea', name: 'Iraqi Kurdistan' },
      ],
      knowsAbout: [
        'LGBTQ rights in Iraq',
        'Hormone replacement therapy',
        'Harm reduction',
        'Digital safety',
        'Mental health',
        'Honor violence prevention',
        'Asylum information',
      ],
      sameAs: [],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      url: siteUrl,
      name: siteName,
      description: description,
      inLanguage: ['en', 'ar'],
      publisher: { '@id': `${siteUrl}#org` },
    },
  ],
};
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline' https://plausible.io; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src https://plausible.io https://api.ispc-iq.org"
    />
    <meta http-equiv="X-Frame-Options" content="DENY" />
    <meta name="referrer" content="no-referrer" />
    <meta name="robots" content="index, follow" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords ?? defaultKeywords} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    <link rel="alternate" hreflang={otherLang} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={new URL(import.meta.env.BASE_URL, Astro.site).href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={lang === 'ar' ? 'ar_IQ' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'ar' ? 'en_US' : 'ar_IQ'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={siteName} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="geo.region" content="IQ" />
    <meta name="geo.placename" content="Iraq" />
    <meta name="theme-color" content="#0d1b2e" />
    <meta name="color-scheme" content="light" />
    {article && (
      <>
        <meta property="article:published_time" content={article.publishedTime} />
        {article.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}
        <meta property="article:author" content={siteName} />
        {article.section && <meta property="article:section" content={article.section} />}
        {article.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
      </>
    )}
    <script type="application/ld+json" set:html={JSON.stringify(baseOrgGraph)} />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <script is:inline>
      (function(){try{var p=window.location.pathname,l=p.split('/')[1];if(l==='en'||l==='ar')localStorage.setItem('ispc-lang',l);}catch(e){}})();
    </script>
  </head>
  <body class="bg-offwhite text-body min-h-screen flex flex-col">
    <QuickExit lang={lang} />
    {showBanner && (
      <div class="bg-exit-red text-white text-center text-sm py-2 px-4 font-semibold" role="alert">
        {lang === 'ar'
          ? 'خصوصيتك مهمة. استخدم VPN. اضغط ESC في أي وقت للخروج فوراً.'
          : 'Your privacy matters. Use a VPN. Press ESC at any time to exit instantly.'}
      </div>
    )}
    <Nav lang={lang} currentPath={currentPath} />
    <main class:list={[
      'flex-1 mx-auto w-full px-4 py-8',
      articleWidth ? 'max-w-[680px]' : 'max-w-[1080px]',
    ]}>
      <slot />
    </main>
    <Footer lang={lang} />
    <PrivacyBanner lang={lang} />
  </body>
</html>

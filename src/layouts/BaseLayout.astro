---
// Font CSS — @fontsource packages declare each @font-face with its own
// `unicode-range`, so even though all 16 face declarations land in one
// bundled CSS chunk, the browser only downloads the woff2 files for
// character ranges that actually appear on the rendered page. EN-only
// pages do not download the Arabic woff2 (~92KB); AR-only pages do not
// download the Latin/Latin-Ext woff2s. So shipping all faces to all
// pages is fine — the actual bytes are conditional via unicode-range.
import '@fontsource/libre-baskerville/400.css';
import '@fontsource/libre-baskerville/700.css';
import '@fontsource-variable/source-sans-3/index.css';
import '@fontsource-variable/noto-naskh-arabic/index.css';
import '@styles/global.css';

import type { Lang } from '@i18n/languages';
import { isRtl, ogLocaleFor, languages } from '@i18n/languages';
import { t, getOtherLangs } from '@i18n/utils';
import QuickExit from '@components/QuickExit.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import PrivacyBanner from '@components/PrivacyBanner.astro';

interface ArticleMeta {
  publishedTime: string;
  modifiedTime?: string;
  section?: string;
  tags?: string[];
}

interface Props {
  title: string;
  description: string;
  lang: Lang;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
  articleWidth?: boolean;
  showBanner?: boolean;
  keywords?: string;
  /** Optional override for og:image. Defaults to /og-image.png. */
  ogImage?: string;
  /** Emitted as `article:*` meta tags when present. ArticleLayout populates this. */
  article?: ArticleMeta;
  /** When true, emit robots=noindex so search engines skip this page (e.g. stub fallbacks). */
  noindex?: boolean;
  /** Override the canonical URL — used by CKB stubs to point search engines at the AR original. */
  canonicalOverride?: string;
}

const {
  title,
  description,
  lang,
  ogType = 'website',
  jsonLd,
  articleWidth = false,
  showBanner = false,
  keywords,
  ogImage,
  article,
  noindex = false,
  canonicalOverride,
} = Astro.props;

const dir = isRtl(lang) ? 'rtl' : 'ltr';
const siteName = t(lang, 'site.name');
const fullTitle = `${title} | ${siteName}`;
const currentPath = Astro.url.pathname;

// Per-language default keyword bundles. Sorani inherits Arabic search terms
// (Sorani readers in Iraq are typically AR-literate too) plus core Sorani
// queer terminology so AI/SE queries in Sorani also surface ISPC pages.
const defaultKeywordsByLang: Record<Lang, string> = {
  en: 'queer Iraq, LGBTQ Iraq, LGBT Iraq, gay Iraq, lesbian Iraq, trans Iraq, transgender Iraq, bisexual Iraq, queer Baghdad, queer Erbil, queer Basra, queer Mosul, queer Kurdistan, LGBT Kurdistan, Iraqi Kurdistan LGBT, HRT Iraq, hormones Iraq, estrogen Iraq, testosterone Iraq, cyproterone Iraq, Androcur Iraq, bicalutamide Iraq, spironolactone Iraq, where to buy hormones Iraq, Iraq pharmacy hormones, Iraq anti-LGBT law, Iraq Law 14 2024, Article 394 Iraq, queer asylum Iraq, Rainbow Railroad Iraq, gender identity, mental health Iraq, harm reduction Iraq, مثليين, متحولين, العراق, بغداد, كردستان, هرمونات, علاج هرموني, دعم نفسي, كوير, جرائم الشرف',
  ar: 'مثليين, مثلية, متحولين جنسياً, متحولات جنسياً, مزدوج الجنس, كوير, ميم عين, هوية جندرية, هوية جنسية, دعم نفسي, الصحة النفسية, اكتئاب, قلق, العراق, بغداد, البصرة, الموصل, أربيل, السليمانية, كردستان, كردستان العراق, علاج هرموني, هرمونات, إستروجين, تستوستيرون, سايبروترون, أندروكور, بيكالوتاميد, مذخر العراق, صيدلية هرمونات, جرائم الشرف, العنف الأسري, لجوء, VPN, خصوصية, حذف السجل, هل أنا مثلي, هل أنا متحول, كيف أعرف أني كوير, تقبّل الذات',
  ckb: 'کوێر, کوێرە عێراقییەکان, ال جی بی تی, هاوڕەگەز, ترانس, چارەسەری هۆرمۆنی, هۆرمۆن لە عێراق, ئەستراژین, تەستۆستیرۆن, سایبرۆترۆن, ئەندرۆکور, ناسنامەی جێندەری, تەندروستیی دەروونی, کوردستان, هەولێر, سلێمانی, دهۆک, یاسای ١٤ عێراق, دژبە مافی کوێرە عێراقییەکان, پەنابەری, تایبەتمەندی, VPN, مثليين, متحولين, العراق, كردستان, هرمونات, علاج هرموني',
};
const defaultKeywords = defaultKeywordsByLang[lang];

const canonicalUrl = canonicalOverride ?? new URL(currentPath, Astro.site).href;
const otherLangsList = getOtherLangs(lang);
// Anchored to the leading lang segment so substrings like "/menu/" or
// "/center/" inside future slugs don't get mangled.
const alternates = otherLangsList.map((other) => ({
  lang: other,
  href: new URL(
    currentPath.replace(/^\/(en|ar|ckb)(\/|$)/, `/${other}$2`),
    Astro.site,
  ).href,
}));
const ogImageUrl = new URL(ogImage ?? '/og-image.png', Astro.site).href;
const siteUrl = new URL('/', Astro.site).href;

const baseOrgGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}#org`,
      name: siteName,
      alternateName: otherLangsList.map((l) => t(l, 'site.name')),
      url: siteUrl,
      logo: ogImageUrl,
      description: t(lang, 'home.about.p1'),
      areaServed: [
        { '@type': 'Country', name: 'Iraq' },
        { '@type': 'AdministrativeArea', name: 'Iraqi Kurdistan' },
      ],
      knowsAbout: [
        'LGBTQ rights in Iraq',
        'Hormone replacement therapy',
        'Harm reduction',
        'Digital safety',
        'Mental health',
        'Honor violence prevention',
        'Asylum information',
      ],
      sameAs: [],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      url: siteUrl,
      name: siteName,
      description: description,
      inLanguage: Object.keys(languages),
      publisher: { '@id': `${siteUrl}#org` },
    },
  ],
};
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline' https://plausible.io; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src https://plausible.io https://api.ispc-iq.org"
    />
    <meta http-equiv="X-Frame-Options" content="DENY" />
    <meta name="referrer" content="no-referrer" />
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords ?? defaultKeywords} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.lang} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(import.meta.env.BASE_URL, Astro.site).href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocaleFor[lang]} />
    {otherLangsList.map((l) => (
      <meta property="og:locale:alternate" content={ogLocaleFor[l]} />
    ))}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={siteName} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="geo.region" content="IQ" />
    <meta name="geo.placename" content="Iraq" />
    <meta name="theme-color" content="#0d1b2e" />
    <meta name="color-scheme" content="light" />
    {article && (
      <>
        <meta property="article:published_time" content={article.publishedTime} />
        {article.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}
        <meta property="article:author" content={siteName} />
        {article.section && <meta property="article:section" content={article.section} />}
        {article.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
      </>
    )}
    <script type="application/ld+json" set:html={JSON.stringify(baseOrgGraph)} />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <link rel="author" href={new URL('/humans.txt', Astro.site).href} />
    <link rel="alternate" type="text/plain" title="LLM-friendly site index" href={new URL('/llms.txt', Astro.site).href} />
    <script is:inline>
      (function(){try{var p=window.location.pathname,l=p.split('/')[1];if(l==='en'||l==='ar'||l==='ckb')localStorage.setItem('ispc-lang',l);}catch(e){}})();
    </script>
  </head>
  <body class="bg-offwhite text-body min-h-screen flex flex-col">
    <QuickExit lang={lang} />
    {showBanner && (
      <div class="bg-exit-red text-white text-center text-sm py-2 px-4 font-semibold" role="alert">
        {t(lang, 'safety.banner')}
      </div>
    )}
    <Nav lang={lang} currentPath={currentPath} />
    <main class:list={[
      'flex-1 mx-auto w-full px-4 py-8',
      articleWidth ? 'max-w-[680px]' : 'max-w-[1080px]',
    ]}>
      <slot />
    </main>
    <Footer lang={lang} />
    <PrivacyBanner lang={lang} />
  </body>
</html>

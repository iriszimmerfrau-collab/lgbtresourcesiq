---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionDivider from '@components/SectionDivider.astro';
import TranslationBanner from '@components/TranslationBanner.astro';
import { localizedPath } from '@i18n/utils';

const lang = 'ckb' as const;
---

<BaseLayout
  title="سەلامەتیی دیجیتاڵی"
  description="ڕێنماییەکی گشتی بۆ پاراستنی خۆت لە کاتی گەڕاندا. دوگمەی دەرچوونی خێرا، سڕینەوەی مێژوو، VPN، و ئامۆژگاریی زیاتری سەلامەتیی دیجیتاڵی."
  lang={lang}
  articleWidth
>
  <section class="prose">
    <SectionDivider />
    <h1>سەلامەتیی دیجیتاڵی</h1>

    <TranslationBanner lang={lang} arHref={localizedPath('ar', '/safety')} />

    <p>
      سەلامەتیت ئەولەویەتی سەرەکیمانە. ئەم پەڕە ئەو ئامرازانە شی دەکاتەوە
      کە ماڵپەڕەکە بۆ پاراستنت دابینی دەکات، و بە ڕاشکاوی ڕوون دەکاتەوە
      چی دەتوانیت بکەیت و چی ناتوانیت. بە وردی بیخوێنەرەوە.
    </p>

    <!-- ===== Quick Exit ===== -->
    <hr />
    <h2>دوگمەی دەرچوونی خێرا (ESC)</h2>

    <p>
      لە سەرەوەی هەموو پەڕەیەکدا دوگمەی <strong>دەرچوونی خێرا</strong> هەیە، و
      دەتوانیت هەروەها لە هەر کاتێکدا کلیلی <strong>ESC</strong> بکێشە. کاتێک چالاک
      دەکرێت:
    </p>

    <ul>
      <li>پەڕەکە دەستبەجێ لە دیمەن دەسڕێتەوە و لە دوگمەی گەڕانەوەدا دەگۆڕێت.</li>
    </ul>

    <h3>سنوورەکان. بە باشی بیخوێنەرەوە</h3>

    <div class="border-2 border-exit-red bg-exit-red/5 p-4 my-4">
      <p class="font-semibold text-exit-red mb-2">ئاگادارییە گرنگەکان</p>
      <ul>
        <li><strong>مێژووی گەڕان ناسڕێتەوە</strong>. دەبێت بە دەستی بیسڕیتەوە (سەیری هەنگاوەکانی خوارەوە بکە).</li>
        <li><strong>بەستەرە بوکمارکراوەکان، پڕکردنەوەی ئۆتۆماتیکی، یان وشە نهێنییە هەڵگیراوەکان ناسڕێتەوە.</strong></li>
        <li><strong>سەردانەکە لە چاودێرەری تۆڕ ناشاردێتەوە</strong> یان لە تۆمارەکانی ڕاوتەر. دابینکەری ئینتەرنێت یان بەڕێوەبەری تۆڕ دەتوانێت ئەو ماڵپەڕانە ببینێت کە سەردانیان دەکەیت.</li>
        <li><strong>بە تەواوی پێشنیار دەکرێت VPN بەکاربێنیت</strong> بۆ شیفرەکردنی هاتنوچوونی داتا (سەیری پێشنیارەکانی خوارەوە بکە).</li>
        <li><strong>گەڕانی شاراوە (Incognito)</strong> ڕێگری لە هەڵگرتنی مێژوو لە سەر ئامێرەکەت دەکات، بەڵام هاتنوچوون لە تۆڕەکە ناشاردێتەوە.</li>
      </ul>
    </div>

    <!-- ===== Clear History ===== -->
    <hr />
    <h2>چۆن مێژووی گەڕان بسڕیتەوە</h2>

    <h3>Chrome لە سەر Android</h3>
    <ol>
      <li>Chrome بکەرەوە و سێ خاڵەکە (&#8942;) لە گۆشەی سەرەوە بکێشە.</li>
      <li><strong>مێژوو</strong> (History) هەڵبژێرە.</li>
      <li><strong>سڕینەوەی داتای گەڕان</strong> (Clear browsing data) بکێشە.</li>
      <li><strong>هەموو کات</strong> (All time) هەڵبژێرە و <strong>سڕینەوەی داتا</strong> بکێشە.</li>
    </ol>

    <h3>Samsung Internet</h3>
    <ol>
      <li>وێبگەڕەکە بکەرەوە و سێ هێڵەکە (&#9776;) بکێشە، پاشان <strong>ڕێکخستن</strong>.</li>
      <li><strong>تایبەتمەندی و سەلامەتی</strong> (Privacy and security) هەڵبژێرە.</li>
      <li><strong>سڕینەوەی داتای گەڕان</strong> (Delete browsing data) بکێشە.</li>
      <li>هەموو هەڵبژاردنەکان دیاری بکە و <strong>سڕینەوە</strong> بکێشە.</li>
    </ol>

    <h3>Firefox لە سەر Android</h3>
    <ol>
      <li>Firefox بکەرەوە و سێ خاڵەکە (&#8942;) بکێشە.</li>
      <li><strong>ڕێکخستن</strong> (Settings) هەڵبژێرە، پاشان <strong>سڕینەوەی داتای گەڕان</strong>.</li>
      <li>هەموو هەڵبژاردنەکان دیاری بکە و <strong>سڕینەوەی داتای گەڕان</strong> بکێشە.</li>
    </ol>

    <!-- ===== VPN ===== -->
    <hr />
    <h2>پێشنیارەکانی VPN</h2>

    <p>
      تۆڕی VPN پەیوەندیی ئینتەرنێتت شیفرە دەکات و ئەو ماڵپەڕانە لە دابینکەری
      خزمەتگوزاری و بەڕێوەبەری تۆڕ دەشاردێتەوە کە سەردانیان دەکەیت.
      <strong>هەمیشە</strong> بەکاری بێنە کاتێک ئەم ماڵپەڕە دەگەڕێیت.
    </p>

    <ul>
      <li>
        <strong>Proton VPN</strong> (بێبەرامبەر). لە هەمان کۆمپانیاوەیە کە ProtonMail پێشکەش دەکات.
        پلانی بێبەرامبەر بێ سنووری داتا و بێ ڕاگەیاندن.
      </li>
      <li>
        <strong>Cloudflare Warp</strong> (بێبەرامبەر). ئەپڵیکەیشنی 1.1.1.1 لە Cloudflare.
        خێرا و ئاسانە بۆ بەکارهێنان، وەک VPNیەکی سەرەکی کار دەکات.
      </li>
    </ul>

    <!-- ===== ProtonMail ===== -->
    <hr />
    <h2>ئیمەیڵی پارێزراو</h2>

    <p>
      پێشنیار دەکەین <strong>ProtonMail</strong> بەکاربێنیت بۆ هەر پەیوەندییەکی هەستیار.
      پۆستە شیفرەکراوە لە یەک لایەنەوە بۆ لایەنی تر، و بارەگاکەی لە سویسرایە
      دوور لە دەستی حکومەتە ناوچەییەکان. دەتوانیت بەبێ ژمارەی تەلەفون
      هەژمارێکی بێبەرامبەر دروست بکەیت.
    </p>

    <!-- ===== Fake Location ===== -->
    <hr />
    <h2>ئەپڵیکەیشنەکانی شوێنی درۆیین</h2>

    <p>
      هەندێک ئەپڵیکەیشن داوای دەستکەوتنی شوێن دەکەن. دەتوانیت ئەپڵیکەیشنەکانی
      "Fake GPS Location" لە سەر Android بەکاربێنیت بۆ پیشاندانی شوێنی درۆیین کە
      شوێنی ڕاستەقینەی تۆ بپارێزێت. لە کۆگای ئەپڵیکەیشنەکاندا "Fake GPS" بگەڕێ.
    </p>

    <!-- ===== Device Warnings ===== -->
    <hr />
    <h2>ئاگادارییە گشتییەکان</h2>

    <div class="border-2 border-exit-red bg-exit-red/5 p-4 my-4">
      <p class="font-semibold text-exit-red mb-2">ئەمە مەکە</p>
      <ul>
        <li><strong>ئەم ماڵپەڕە لە سەر ئامێرێکی هاوبەشدا بەکارمەهێنە</strong>. ئەگەر کەسێکی تر هەمان تەلەفۆن یان کۆمپیوتەر بەکار بهێنێت، لەوانەیە مێژووی گەڕانەکە ببینێت.</li>
        <li><strong>لە سەر هەمان شەبەکەی وایفای مەگەڕێ</strong> لەگەڵ کەسانێک کە متمانەیان پێ ناکەیت. بەڕێوەبەری تۆڕ دەتوانێت چاودێریی هاتنوچوون بکات. VPN یان داتای تەلەفۆن بەکاربێنە.</li>
      </ul>
    </div>

    <!-- ===== Passwords ===== -->
    <hr />
    <h2>وشە نهێنییەکان و پشتڕاستکردنەوە</h2>

    <ul>
      <li>
        <strong>وشە نهێنییەکی بەهێز بەکاربێنە</strong>. لانیکەم ١٢ پیت، تێکەڵە لە
        پیتی گەورە و بچووک و ژمارە و سیمبۆلەکان. ناوی خۆت یان ڕێکەوتی لەدایکبوونت بەکارمەهێنە.
      </li>
      <li>
        <strong>پشتڕاستکردنەوەی دووانە (2FA) چالاک بکە</strong>. لە هەموو هەژمارێکدا کە پشتیوانیی لێ دەکات.
        تەنانەت ئەگەر وشە نهێنییەکەت دزرابوو، هیچ کەس بەبێ کۆدی دووەم نایەتە ژوورەوە.
      </li>
    </ul>

    <!-- ===== Email Reuse ===== -->
    <hr />
    <h2>ئیمەیڵی چالاکت دووبارە بەکارمەهێنە</h2>

    <div class="border-2 border-exit-red bg-exit-red/5 p-4 my-4">
      <p class="font-semibold text-exit-red mb-2">ئاگاداری</p>
      <p>
        ئیمەیڵی کەسی یان فەرمی خۆت بەکارمەهێنە بۆ تۆمارکردن لە هیچ خزمەتگوزارییەک
        کە پەیوەستە بە ناسنامەی کوێرەکەت. ئیمەیڵێکی نوێ دروست بکە (پێشنیار دەکرێت ProtonMail)
        کە ناوی ڕاستەقینەی تێدا نییە، و بە تەنیا بۆ ئەم مەبەستە بەکاری بێنە.
      </p>
    </div>

    <!-- ===== EXIF ===== -->
    <hr />
    <h2>داتای EXIF لە وێنەکاندا</h2>

    <div class="border-2 border-exit-red bg-exit-red/5 p-4 my-4">
      <p class="font-semibold text-exit-red mb-2">ئاگاداری</p>
      <p>
        ئەو وێنانەی کە بە تەلەفۆنەکەت گیراون داتای شاراوەیان تێدایە بە ناوی EXIF , 
        ئەمە کۆئۆردیناتە GPSی وردەکان، جۆری ئامێر، و کات و ڕێکەوت لەخۆدەگرێت. ئەگەر
        وێنەیەک لە ڕێگەی ئینتەرنێتەوە بەشداری بکەیت، لەوانەیە شوێنی ڕاستەقینەت ئاشکرا بکات.
        پێش هەر بەشدارییەک داتای EXIF بسڕەوە بە بەکارهێنانی ئەپڵیکەیشنێک وەک
        "Scrambled Exif" یان وێنەکان بنێرە لە ڕێگەی ئەپڵیکەیشنێکەوە کە داتاکان بە
        ئۆتۆماتیکی دەسڕێتەوە (وەک Signal).
      </p>
    </div>

    <!-- ===== Instagram ===== -->
    <hr />
    <h2>ئامۆژگاریی سەلامەتیی Instagram</h2>

    <ul>
      <li>هەژمارەکەت بکە بە <strong>تایبەت</strong> (Private) هەمیشە.</li>
      <li>وێنە یان ناوی ڕاستەقینەی خۆت بەکارمەهێنە.</li>
      <li><strong>دۆخی چالاکی</strong> (Activity Status) لە ڕێکخستنەکاندا ناچالاک بکە.</li>
      <li>هەژماری Instagram مەبەستە بە ژمارەی تەلەفۆن یان هەژمار کە کەسانێک لە ژیانی ڕۆژانەتدا دەیناسن.</li>
      <li><strong>لیستی شوێنکەوتووان</strong> بەشێوەیەکی ڕێکوپێک پێداچوونەوەی بکە و هەر هەژمارێک کە نایناسیت بیسڕەوە.</li>
      <li>شوێنی خۆت لە چیرۆکەکاندا (Stories) یان پۆستەکاندا بەشداری مەکە.</li>
    </ul>
  </section>
</BaseLayout>

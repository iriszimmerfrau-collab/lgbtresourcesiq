  articleWidth
  jsonLd={jsonLd}
  keywords="پرسیاری کوێرە عێراقییەکان, مثلیی عێراق, متحول عێراق, هۆرمۆنی عێراق, یاسای دژبە مثلی, پەنابەری مثلیی عێراق, کوێر بەغداد, کوێر هەولێر, کوێر کوردستان"
>
  <section class="prose">
    <SectionDivider />
    <h1>پرسیارە دووبارەکراوەکان</h1>

    <TranslationBanner lang={lang} arHref={localizedPath('ar', '/faq')} />

    <p>
      پرسیاری ڕاستەقینەی کوێرە عێراقییەکان. وەڵامەکان بە زمانێکی سادە نووسراون، لەگەڵ بەستەر بۆ
      ڕێنمایی قووڵتر کاتێک پێویستە. ئەگەر پرسیارەکەت لێرە نییە، بنووسە بۆمان. سەیری
      <a href={localizedPath(lang, '/community')}>پەڕەی کۆمەڵگا</a> بکە.
    </p>

    <hr />

    {faqs.map(({ q, a }) => (
      <article class="mb-8">
        <h2 class="text-xl font-bold mb-2">{q}</h2>
        <p set:html={a.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>').replace(/`([^`]+)`/g, '<code>$1</code>')} />
      </article>
    ))}
  </section>
</BaseLayout>

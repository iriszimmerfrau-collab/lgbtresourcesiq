---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionDivider from '@components/SectionDivider.astro';
import TranslationBanner from '@components/TranslationBanner.astro';
import { localizedPath } from '@i18n/utils';

const lang = 'ckb' as const;
---

<BaseLayout
  title="دەربارەی ئێمە"
  description="بناسە کۆڕی پێشکەوتنی کۆمەڵایەتیی عێراق. تۆڕێکی هاوکارییە بۆ کوێرە عێراقییەکان. بنەماکانمان، پێکهاتەکەمان، و ئەوەی نین."
  lang={lang}
  articleWidth
>
  <section class="prose">
    <SectionDivider />
    <h1>دەربارەی ئێمە</h1>

    <TranslationBanner lang={lang} arHref={localizedPath('ar', '/about')} />

    <p>
      <strong>کۆڕی پێشکەوتنی کۆمەڵایەتیی عێراق</strong> تۆڕێکی هاوکاریی خەڵکییە
      بۆ کوێرە عێراقییەکان و کەسانی پرسیارلێکراو لە ناوەوەی عێراق. زانیاریی
      پشتڕاستکراو دابین دەکەین، و شوێنێکی سەلامەت بۆ پەیوەندی و هاودەنگی
      دروست دەکەین. دوور لە هەر دامەزراوەیەکی فەرمی.
    </p>

    <hr />

    <h2>بنەماکانمان</h2>

    <ul>
      <li><strong>هاوکاریی کۆمەڵایەتی</strong>. یەکتری پشتیوانی دەکەین وەک ئەوەی دراوسێ پشتیوانی دراوسێی دەکات، بێ مەرج و بێ پلەبەندی.</li>
      <li><strong>تایبەتمەندی لە پێشدا</strong>. هەموو بڕیارێکی تەکنیکی و ناوەڕۆکێک لەسەر بناغەی پاراستنی ناسنامەکەت دادەنرێت.</li>
      <li><strong>لە عێراقییەکانەوە بۆ عێراقییەکان</strong>. لە بارودۆخەکە تێدەگەین چونکە تێیدا دەژین.</li>
      <li><strong>سەربە هیچ حکومەت یان حزبێک نین</strong>. بێ پاڵپشتی حکومی، بێ ئاجیندای حزبی، بێ دڵسۆزی جگە لە کۆمەڵگامان.</li>
    </ul>

    <hr />

    <h2>ئەوەی نین</h2>

    <p>گرنگە بزانیت سنوورەکانی ئەوەی پێشکەشی دەکەین:</p>

    <ul>
      <li><strong>ڕێکخراوێکی خێرخوازی نین</strong>. پارە یان یارمەتیی ماددی دابەش ناکەین. ئێمە تۆڕی زانیاری و هاودەنگیین.</li>
      <li><strong>ڕێکخراوێکی میدیایی نین</strong>. هەواڵ بڵاو ناکەینەوە و بەدوای ناوبانگ یان داپۆشینی میدیایی نین.</li>
      <li><strong>یارمەتییەکی پەنابەری نین</strong>. ناتوانین ڕاوێژی یاسایی پێشکەش بکەین یان ڕێکارەکانی پەنابەری ئاسان بکەین.</li>
      <li><strong>جێگرەوەی پزیشک نین</strong>. زانیاریی تەندروستیمان تەنیا بۆ پەروەردەیە، نەک دەستنیشانکردن یان چارەسەر.</li>
    </ul>

    <hr />

    <h2>پێکهاتەکەمان</h2>

    <ul>
      <li><strong>دابەشکراو</strong>. هیچ بارەگایەکی یەکگرتوو یان سێرڤەرێکی ناوەندی نییە کە بکرێت داببخرێت.</li>
      <li><strong>شیفرەکراو</strong>. پەیوەندییە ناوخۆییەکانمان لە یەک لایەنەوە بۆ لایەنی تر شیفرەکراون.</li>
      <li><strong>بنیاتنراو لەسەر متمانە</strong>. بە نیازی باشەوە دەچینە هەر پەیوەندییەک، و پاراستنی متمانەتان وەک ئەولەویەتێکی سەرەکی هەژمار دەکەین.</li>
    </ul>

    <hr />

    <blockquote>
      بە دەستی کوێرە عێراقییەکان و هاوڕێیانی عێراق دروستکراوە.
    </blockquote>
  </section>
</BaseLayout>

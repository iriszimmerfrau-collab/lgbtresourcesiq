---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ArticleLayout from '@layouts/ArticleLayout.astro';
import CkbStub from '@components/CkbStub.astro';
import TranslationBanner from '@components/TranslationBanner.astro';
import { estimateReadingTime, getSlugFromId } from '@lib/collections';
import { buildArticleSchema, buildBreadcrumbList, combineSchemas, type JsonLdContext } from '@lib/jsonld';
import { localizedPath, t } from '@i18n/utils';

export async function getStaticPaths() {
  const ckb = await getCollection('news', (e: CollectionEntry<'news'>) => e.data.lang === 'ckb' && !e.data.draft);
  const ar = await getCollection('news', (e: CollectionEntry<'news'>) => e.data.lang === 'ar' && !e.data.draft);
  const realCkbSlugs = new Set(ckb.map((n) => getSlugFromId(n.id)));

  const realPaths = ckb.map((item) => ({
    params: { slug: getSlugFromId(item.id) },
    props: { kind: 'real' as const, item },
  }));

  const stubPaths = ar
    .filter((n) => !realCkbSlugs.has(getSlugFromId(n.id)))
    .map((n) => {
      const slug = getSlugFromId(n.id);
      return {
        params: { slug },
        props: { kind: 'stub' as const, slug, title: n.data.title },
      };
    });

  return [...realPaths, ...stubPaths];
}

type Props =
  | { kind: 'real'; item: CollectionEntry<'news'> }
  | { kind: 'stub'; slug: string; title: string };

const props = Astro.props as Props;
const lang = 'ckb' as const;

let Content: any = null;
let item: CollectionEntry<'news'> | null = null;
let readingTime = 0;
let jsonLd: Record<string, unknown> | null = null;
let articleMeta: { publishedTime: string; section?: string; tags?: string[] } | undefined;
let arHref = '';
let showBanner = false;

if (props.kind === 'real') {
  item = props.item;
  ({ Content } = await render(item));
  readingTime = estimateReadingTime(item.body ?? '');

  const siteUrl = new URL('/', Astro.site).href;
  const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
  const ctx: JsonLdContext = { lang, pageUrl, siteUrl, siteName: 'کۆڕی پێشکەوتنی کۆمەڵایەتیی عێراق' };

  jsonLd = combineSchemas(
    buildArticleSchema(item, ctx),
    buildBreadcrumbList([
      { name: t(lang, 'nav.home'), url: new URL(localizedPath(lang, '/'), Astro.site).href },
      { name: t(lang, 'nav.news'), url: new URL(localizedPath(lang, '/news'), Astro.site).href },
      { name: item.data.title, url: pageUrl },
    ]),
  );

  articleMeta = {
    publishedTime: item.data.pubDate.toISOString(),
    section: 'news',
    tags: item.data.keywords?.split(',').map((s) => s.trim()).filter(Boolean),
  };

  arHref = localizedPath('ar', `/news/${getSlugFromId(item.id)}`);
  showBanner = item.data.translationStatus !== 'native';
}
---

{props.kind === 'stub' ? (
  <CkbStub title={props.title} arHref={`/ar/news/${props.slug}`} pageLabel="هەواڵ" />
) : (
  <ArticleLayout
    title={item!.data.title}
    description={item!.data.description}
    lang={lang}
    pubDate={item!.data.pubDate}
    readingTime={readingTime}
    jsonLd={jsonLd}
    keywords={item!.data.keywords}
    ogImage="/og-guide.png"
    article={articleMeta}
  >
    {showBanner && <TranslationBanner lang={lang} arHref={arHref} />}
    <Content />
    {item!.data.source && (
      <footer class="mt-12 pt-6 border-t border-muted/20 text-sm text-muted">
        <p>
          <strong>سەرچاوە:</strong>{' '}
          {item!.data.sourceUrl
            ? <a href={item!.data.sourceUrl} target="_blank" rel="noopener noreferrer">{item!.data.source}</a>
            : item!.data.source}
        </p>
      </footer>
    )}
  </ArticleLayout>
)}

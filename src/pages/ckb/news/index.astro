---
import BaseLayout from '@layouts/BaseLayout.astro';
import Card from '@components/Card.astro';
import { t, localizedPath } from '@i18n/utils';
import { getCollectionByLang, getSlugFromId } from '@lib/collections';

const lang = 'ckb' as const;
const news = await getCollectionByLang('news', lang);

news.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title={t(lang, 'nav.news')}
  description="هەواڵ و نوێکارییە پەیوەستەکان بە کوێرە عێراقییەکان و کۆمەڵگای فراوانتر."
  lang={lang}
>
  <section class="py-8">
    <h1 class="text-3xl font-bold mb-2">{t(lang, 'nav.news')}</h1>
    <p class="text-muted mb-8">هەواڵ و نوێکارییە پەیوەستەکان بە کۆمەڵگاکەمان.</p>
    {news.length === 0 ? (
      <p class="text-muted py-8">هێشتا هیچ هەواڵێک بە کوردی بەردەست نییە. <a href="/ar/news" class="underline font-semibold">نوسخەی عەرەبیی ببینە</a>.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {news.map((item) => (
          <Card
            title={item.data.title}
            description={item.data.description}
            href={localizedPath(lang, `/news/${getSlugFromId(item.id)}`)}
            date={item.data.pubDate}
            lang={lang}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>

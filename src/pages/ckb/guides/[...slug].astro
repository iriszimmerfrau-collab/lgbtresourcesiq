---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ArticleLayout from '@layouts/ArticleLayout.astro';
import GuideNav from '@components/GuideNav.astro';
import CkbStub from '@components/CkbStub.astro';
import TranslationBanner from '@components/TranslationBanner.astro';
import { getSlugFromId, estimateReadingTime } from '@lib/collections';
import {
  buildArticleSchema,
  buildMedicalWebPageSchema,
  buildLearningResourceSchema,
  buildBreadcrumbList,
  combineSchemas,
  type JsonLdContext,
} from '@lib/jsonld';
import { localizedPath, t } from '@i18n/utils';

/**
 * Renders real Sorani guides when present in the ckb collection; falls
 * back to a CkbStub (noindex, canonical→AR) for AR slugs not yet
 * translated. Real CKB pages render the TranslationBanner unless
 * frontmatter sets translationStatus: 'native'.
 */
export async function getStaticPaths() {
  const ckb = await getCollection('guides', (e: CollectionEntry<'guides'>) => e.data.lang === 'ckb' && !e.data.draft);
  const ar = await getCollection('guides', (e: CollectionEntry<'guides'>) => e.data.lang === 'ar' && !e.data.draft);
  const realCkbSlugs = new Set(ckb.map((g) => getSlugFromId(g.id)));

  const realPaths = ckb.map((guide) => ({
    params: { slug: getSlugFromId(guide.id) },
    props: { kind: 'real' as const, guide },
  }));

  const stubPaths = ar
    .filter((g) => !realCkbSlugs.has(getSlugFromId(g.id)))
    .map((g) => {
      const slug = getSlugFromId(g.id);
      return {
        params: { slug },
        props: { kind: 'stub' as const, slug, title: g.data.title },
      };
    });

  return [...realPaths, ...stubPaths];
}

type Props =
  | { kind: 'real'; guide: CollectionEntry<'guides'> }
  | { kind: 'stub'; slug: string; title: string };

const props = Astro.props as Props;

// Stub branch
const stubTitle = props.kind === 'stub' ? props.title : '';
const stubArHref = props.kind === 'stub' ? `/ar/guides/${props.slug}` : '';

// Real branch
let Content: any = null;
let guide: CollectionEntry<'guides'> | null = null;
let lang: 'ckb' = 'ckb';
let slug = '';
let readingTime = 0;
let jsonLd: Record<string, unknown> | null = null;
let ogImage = '/og-guide.png';
let articleMeta: { publishedTime: string; modifiedTime?: string; section?: string; tags?: string[] } | undefined;
let relatedLinks: Array<{ title: string; url: string }> = [];
let arHref = '';
let showBanner = false;

if (props.kind === 'real') {
  guide = props.guide;
  ({ Content } = await render(guide));
  slug = getSlugFromId(guide.id);
  readingTime = estimateReadingTime(guide.body ?? '');

  const siteUrl = new URL('/', Astro.site).href;
  const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
  const ctx: JsonLdContext = {
    lang,
    pageUrl,
    siteUrl,
    siteName: 'کۆڕی پێشکەوتنی کۆمەڵایەتیی عێراق',
  };

  const category = guide.data.category;
  const isMedical = category === 'hrt' || category === 'mental-health';
  const isEducational = category === 'identity' || category === 'general';

  const breadcrumbs = buildBreadcrumbList([
    { name: t(lang, 'nav.home'), url: new URL(localizedPath(lang, '/'), Astro.site).href },
    { name: t(lang, 'nav.guides'), url: new URL(localizedPath(lang, '/guides'), Astro.site).href },
    { name: t(lang, `guides.category.${category}` as any), url: new URL(localizedPath(lang, `/guides#${category}`), Astro.site).href },
    { name: guide.data.title, url: pageUrl },
  ]);

  const primarySchema = isMedical
    ? buildMedicalWebPageSchema(guide, ctx)
    : isEducational
    ? buildLearningResourceSchema(guide, ctx)
    : buildArticleSchema(guide, ctx);

  const articleFallback = isMedical || isEducational ? buildArticleSchema(guide, ctx) : null;
  jsonLd = combineSchemas(primarySchema, articleFallback, breadcrumbs);

  ogImage = isMedical ? '/og-hrt.png' : '/og-guide.png';

  articleMeta = {
    publishedTime: guide.data.pubDate.toISOString(),
    modifiedTime: guide.data.updatedDate?.toISOString(),
    section: category,
    tags: guide.data.keywords?.split(',').map((s) => s.trim()).filter(Boolean),
  };

  if (guide.data.relatedGuides?.length) {
    const ckbAll = await getCollection('guides', (e: CollectionEntry<'guides'>) => e.data.lang === 'ckb' && !e.data.draft);
    const arAll = await getCollection('guides', (e: CollectionEntry<'guides'>) => e.data.lang === 'ar' && !e.data.draft);
    const ckbBySlug = new Map(ckbAll.map((g) => [getSlugFromId(g.id), g]));
    const arBySlug = new Map(arAll.map((g) => [getSlugFromId(g.id), g]));
    relatedLinks = guide.data.relatedGuides
      .map((relSlug) => {
        const ckbHit = ckbBySlug.get(relSlug);
        if (ckbHit) {
          return {
            title: ckbHit.data.title,
            url: new URL(localizedPath('ckb', `/guides/${relSlug}`), Astro.site).href,
          };
        }
        const arHit = arBySlug.get(relSlug);
        if (arHit) {
          return {
            title: arHit.data.title,
            url: new URL(localizedPath('ar', `/guides/${relSlug}`), Astro.site).href,
          };
        }
        return null;
      })
      .filter((x): x is { title: string; url: string } => !!x);
  }

  arHref = localizedPath('ar', `/guides/${slug}`);
  showBanner = guide.data.translationStatus !== 'native';
}
---

{props.kind === 'stub' ? (
  <CkbStub title={stubTitle} arHref={stubArHref} pageLabel="ڕێنمایی" />
) : (
  <ArticleLayout
    title={guide!.data.title}
    description={guide!.data.description}
    lang={lang}
    pubDate={guide!.data.pubDate}
    updatedDate={guide!.data.updatedDate}
    readingTime={readingTime}
    jsonLd={jsonLd}
    keywords={guide!.data.keywords}
    ogImage={ogImage}
    article={articleMeta}
    relatedLinks={relatedLinks}
  >
    {showBanner && <TranslationBanner lang={lang} arHref={arHref} />}
    <Content />
    {guide!.data.parentGuide && (
      <GuideNav lang={lang} parentGuide={guide!.data.parentGuide} currentSlug={slug} />
    )}
  </ArticleLayout>
)}

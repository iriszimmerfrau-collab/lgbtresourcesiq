---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionDivider from '@components/SectionDivider.astro';
import Callout from '@components/Callout.astro';
import ResourceCard from '@components/ResourceCard.astro';
import TranslationBanner from '@components/TranslationBanner.astro';
import { localizedPath } from '@i18n/utils';

const lang = 'ckb' as const;
---

<BaseLayout
  title="کۆمەڵگا"
  description="بەشداربە لە کۆمەڵگای کۆڕی پێشکەوتنی کۆمەڵایەتیی عێراق لە ڕێگەی XMPPی شیفرەکراو. پەیوەندیی پارێزراو، پێویستی بە ژمارەی تەلەفون نییە، و هیچ شوێنپێیەکی دیجیتاڵی نییە."
  lang={lang}
  articleWidth
>
  <section class="prose">
    <SectionDivider />
    <h1>کۆمەڵگا</h1>

    <TranslationBanner lang={lang} arHref={localizedPath('ar', '/community')} />

    <p>
      پرۆتۆکۆلی <strong>XMPP</strong> بەکاردێنین بۆ پەیوەندی لەگەڵ کۆمەڵگاکەمان.
      ئەگەر پێشتر گوێت لێی نەبووە، نیگەران مەبە. هەموو شتێک هەنگاو بە هەنگاو شی دەکەینەوە.
    </p>

    <!-- ===== What is XMPP ===== -->
    <hr />
    <h2>XMPP چییە؟</h2>

    <p>XMPP پرۆتۆکۆلێکی پەیامناردنی سەرچاوەکراوەی هاوبەشە و ئەم تایبەتمەندییانەی هەیە:</p>

    <ul>
      <li><strong>شیفرەکراوە</strong>. پەیامەکان لە یەک لایەنەوە بۆ لایەنی تر بە OMEMO شیفرە کراون، هیچ کەسێک ناتوانێت بیخوێنێتەوە جگە لە تۆ و وەرگرەکە.</li>
      <li><strong>لامەرکەزی</strong>. هیچ کۆمپانیایەکی تاک خاوەنیەتی نییە و هیچ حکومەتێک ناتوانێت دایبخات.</li>
      <li><strong>یەکگرتوو</strong> (Federated). وەک ئیمەیڵ، دەتوانیت هەژمارەکەت لە هەر سێرڤەرێکدا دروست بکەیت و پەیوەندی لەگەڵ بەکارهێنەرانی سێرڤەرە دیکە بکەیت.</li>
      <li><strong>پێویستی بە ژمارەی تەلەفون نییە</strong>. بەپێچەوانەی WhatsApp یان Telegram، XMPP پێویستی بە ژمارەی تەلەفون یان ناسنامەی ڕاستەقینە نییە.</li>
    </ul>

    <!-- ===== Setup Steps ===== -->
    <hr />
    <h2>هەنگاوەکانی ڕێکخستن</h2>

    <h3>١. ئەپڵیکەیشنی Conversations دامەزرێنە</h3>

    <p>
      Conversations باشترین ئەپڵیکەیشنی XMPPە بۆ سیستەمی Android. دەتوانیت بێبەرامبەر
      لە کۆگای F-Droid دایببەزێنیت (پێویستی بە هەژماری Google نییە):
    </p>

    <p>
      <a href="https://f-droid.org/en/packages/eu.siacs.conversations/" target="_blank" rel="noopener noreferrer">
        دابەزاندنی Conversations لە F-Droid
      </a>
    </p>

    <h3>٢. هەژمارێکی بێبەرامبەر تۆمار بکە</h3>

    <p>
      کاتێک ئەپڵیکەیشنەکە بۆ یەکەم جار دەکەیتەوە، "دروستکردنی هەژماری نوێ" هەڵبژێرە. دەتوانیت لە یەکێک
      لەم سێرڤەرە بێبەرامبەرانە تۆمار بکەیت:
    </p>

    <ul>
      <li><strong>conversations.im</strong>. سێرڤەری فەرمیی ئەپڵیکەیشنی Conversations.</li>
      <li><strong>jabber.de</strong>. سێرڤەرێکی ئاڵمانی بێبەرامبەر و متمانەپێکراو.</li>
    </ul>

    <p>
      ناوێکی بەکارهێنەر هەڵبژێرە کە ناسنامەی ڕاستەقینەی تۆ نیشان نەدات. ناوی خۆت یان نازناوت یان ڕێکەوتی لەدایکبوونت بەکارمەهێنە.
    </p>

    <!-- ===== Contact Us ===== -->
    <hr />
    <h2>پەیوەندیمان پێوەبکە</h2>

    <p>دوای دروستکردنی هەژمارەکەت، دەتوانیت بە یەکێک لەم دوو ڕێگەیە بگەیتە ئێمە:</p>

    <h3>XMPP</h3>
    <p>ئەم JID زیاد بکە بۆ پەیوەندییەکانت:</p>
    <p><code class="bg-navy/5 px-2 py-1 font-mono text-sm">iriszimmerfrau@conversations.im</code></p>

    <h3>ProtonMail</h3>
    <p>ئەگەر ئیمەیڵی شیفرەکراوت پێ خۆشترە:</p>
    <p><code class="bg-navy/5 px-2 py-1 font-mono text-sm">iriszimmerfrau@proton.me</code></p>

    <!-- ===== What to Expect ===== -->
    <hr />
    <h2>چاوەڕێی چی بکەیت کاتێک پەیوەندیمان پێوەدەکەیت؟</h2>

    <ul>
      <li>زۆربەی کات لە ماوەی ٤٨ کاتژمێردا وەڵامت دەدەینەوە.</li>
      <li>پرسیاری ناوی ڕاستەقینەت یان شوێنت لێ ناکەین مەگەر پێویست بێت بۆ یارمەتیدانت.</li>
      <li>زانیارییەکانت لەگەڵ هیچ کەسێک هاوبەش ناکەین. هەرگیز.</li>
      <li>دەتوانیت بە کوردی، عەرەبی، یان ئینگلیزی بنووسیت.</li>
      <li>ئەگەر نەتوانین ڕاستەوخۆ یارمەتیت بدەین، هەوڵ دەدەین ئاراستەی سەرچاوەیەکی متمانەپێکراوت بکەین.</li>
    </ul>

    <!-- ===== Anonymous Contribution ===== -->
    <hr />
    <h2>بەشداریی نەناسراو</h2>

    <p>
      چیرۆک یان ئەزموونێکت هەیە دەتەوێت لەگەڵ کۆمەڵگادا هاوبەشی بکەیت؟ دەتوانیت بەتەواوی بەبێ ئاشکراکردنی ناسنامەکەت بیکەیت.
    </p>

    <h3>چۆن چیرۆکەکەت هاوبەشی بکەیت</h3>

    <ol>
      <li>هەژمارێکی XMPPی نوێ بە ناوی خۆکراو دروست بکە کە تۆی پێی نەناسرێیت (هەنگاوەکانی سەرەوە دووبارە بکەرەوە).</li>
      <li>لە <code class="bg-navy/5 px-2 py-1 font-mono text-sm">iriszimmerfrau@conversations.im</code> پەیوەندیمان پێوەبکە و پێمان بڵێ دەتەوێت چیرۆکەکەت هاوبەش بکەیت.</li>
      <li>چیرۆکەکەت بنووسە چۆن دەتەوێت. بە عامی یان فەرمی، درێژ یان کورت.</li>
      <li>لەگەڵت دەیپێداچوێنینەوە و دڵنیا دەبین کە هەر وردەکارییەک کە بتوانێت ناسنامەکەت ئاشکرا بکات، پێش بڵاوکردنەوە لاببرێت.</li>
      <li>هەرگیز هیچ شتێک بەبێ ڕەزامەندیی ڕاشکاوی تۆ بڵاو ناکەینەوە.</li>
    </ol>

    <p>
      دەنگت گرنگە، و چیرۆکەکەت دەکرێت یارمەتیی کەسێکی تر بدات کە هەست بە تەنیایی دەکات.
      هاوبەشی بکە ئەگەر دەتەوێت، بەو شێوەیەی کە لەگەڵتدا گونجاوە.
    </p>

    <!-- ===== External Resources ===== -->
    <hr />
    <h2 id="external-resources">شوێنە کۆمەڵایەتییە دەرەکییەکان</h2>

    <Callout type="warning">
      ئەم شوێنانە شوێنە کۆمەڵایەتییە دەرەکییەکانن، <strong>لەلایەن ISPCەوە بەڕێوە ناچن</strong>.
      لیستیان دەکەین چونکە کوێرە عێراقییەکان لێیان کۆ دەبنەوە. بەڵام هەر پلاتفۆرمێک
      داتای جیاواز دەربارەی تۆ کۆ دەکاتەوە، و ئەوەی لێیاندا بڵاوی دەکەیتەوە لە دەرەوەی
      پاراستنی ئێمەیە. ئاگاداریی هەر پلاتفۆرمێک لە خوارەوە بخوێنەرەوە پێش ئەوەی
      بەشدار بیت. <strong>VPN بەکاربێنە. هەرگیز ناوی ڕاستەقینەت، ژمارەی تەلەفۆنی
      ڕاستەقینەت، یان هیچ وێنەیەک کە بتوانێت ناسنامەکەت ئاشکرا بکات بەکارمەهێنە.
      هەژمارێکی نوێی خۆکراو دروست بکە کە لە هیچ شوێنێکی تردا بەکار نەهێنرابێت.</strong>
    </Callout>

    <h3>Discord</h3>
    <p>
      Discord لە زۆر سێرڤەردا داوای پشتڕاستکردنەوەی ژمارەی تەلەفون دەکات. <strong>ئەمە
      دەتوانێت ژمارەی تەلەفۆنی عێراقییەکەت بۆ Discord و، لە چەند بەرنامەی پێشووداڕەخسانێکدا، بۆ
      بەکارهێنەرانی تر ئاشکرا بکات</strong>. ژمارەیەکی مەجازی یان غەیرە عێراقی بەکاربێنە ئەگەر بکرێت.
      پەیامەکان بە ماوەیەکی نادیار لە سەر سێرڤەرەکانی Discord دەمێننەوە. چاتی دەنگی دەنگت ئاشکرا دەکات.
      وێنەی پرۆفایل بۆ هەموو ئەندامێکی سێرڤەر بەرچاوە. ئەگەر بەشدار بیت، هەژمارێک بەکاربێنە کە
      لە هیچ شوێنێکی تردا بەکارت نەهێناوە.
    </p>
    <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-3 my-4">
      <ResourceCard
        platform="Discord"
        url="https://discord.gg/hCwyVwFB"
        title="Iraqi Pride"
        description="سێرڤەری کۆمەڵگای کوێرە عێراقییەکان. کۆڕەکە ئەم سێرڤەرە بەڕێوە نابات."
      />
      <ResourceCard
        platform="Discord"
        url="https://discord.gg/mazVfWbd7u"
        title="Girls & Gays+IQ"
        description="سێرڤەری کۆمەڵگای کوێرە عێراقییەکان. کۆڕەکە ئەم سێرڤەرە بەڕێوە نابات."
      />
      <ResourceCard
        platform="Discord"
        url="https://discord.gg/2hfjUDBAy"
        title="kurdish closet 🌈"
        description="سێرڤەری کوێری کوردی. زۆربەی کات بە ئینگلیزی، بە توندی SFW، چەند چالاکییەکی هەیە. کۆڕەکە ئەم سێرڤەرە بەڕێوە نابات."
      />
    </div>

    <h3>Reddit</h3>
    <p>
      Reddit ناونیشانی IPت تۆمار دەکات. مێژووی تەواوی کۆمێنت و دەنگدانەکانت
      <strong>بە شێوەی گشتی ئەرشیف کراون</strong>. هەروەها لەلایەن لایەنە سێیەمەکانیشەوە کە
      Reddit دەکۆپین. هەژمارێک کە لە شوێنێکی تردا بەکارت هێنابێت، دەکرێت
      بەرامبەر بە هەر شتێک کە لێرە دەیڵێیت بەشداری بکرێت. هەژمارێکی کاتیی نوێ
      دروست بکە لە پشت VPN، هەرگیز ئەو هەژمارە مەبەستە بە هیچ هەژمارێک کە
      ناسنامەی ڕاستەقینەت دەناسێت، و هەرگیز هیچ شتێک بڵاومەکەرەوە کە نەتەوێت
      چەند ساڵ دواتر دەربکەوێت.
    </p>
    <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-3 my-4">
      <ResourceCard
        platform="Reddit"
        url="https://www.reddit.com/r/iraqpride/"
        title="r/iraqpride"
        description="کۆمەڵگای subreddit بۆ فەخری عێراق. گفتوگۆ و پشتیوانی و ئەزموونی هاوبەش. پۆستەکان و کۆمێنتەکان بە شێوەی گشتی ئەرشیف کراون."
      />
    </div>

    <h3>YouTube</h3>
    <p>
      تەماشاکردن پێویستی بە هەژمار نییە، بەڵام <strong>کۆمێنتکردن، دڵخۆشی، یان بەشداربوون
      پێویستی بە هەژماری Google هەیە</strong>. و Google هەموو تەماشاکردنێکی هاتنە
      ژوورەوەی هەژمارت بەرامبەر ناسنامەی ڕاستەقینەت تۆمار دەکات. تەماشای بکە بەبێ
      هاتنە ژوورەوە، یان لە پەنجەرەیەکی تایبەت / بێ شوێنپێ لە پشت VPN، ئەگەر
      دەتەوێت مێژووی تەماشاکردنت دوور لە پرۆفایلی Google خۆت بهێڵیتەوە. لە هیچ
      هەژمارێک کە پەیوەستە بە ناسنامەی ڕاستەقینەت کۆمێنت مەنووسە.
    </p>
    <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-3 my-4">
      <ResourceCard
        platform="YouTube"
        url="https://www.youtube.com/@ZFVelvetIris"
        title="@ZFVelvetIris (کەناڵ)"
        description="بەرهەمهێنی ناوەڕۆکی کوێری عێراقی. ڤیدیۆ بە عەرەبی و ئینگلیزی دەربارەی ناسنامە و خێزان و ڕزگاربوون."
      />
      <ResourceCard
        platform="YouTube"
        url="https://youtu.be/6pK6ocmt6ZI"
        title="الاشياء الي ما نحجي عنها…"
        description="ڤیدیۆ لە Iris Zimmerfrau."
      />
      <ResourceCard
        platform="YouTube"
        url="https://youtu.be/VtwTQYLHK1A"
        title="عن مجتمع الميم… اساسيات ١٠١!"
        description="ڤیدیۆ لە Iris Zimmerfrau."
      />
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '@layouts/BaseLayout.astro';
import Card from '@components/Card.astro';
import { t, localizedPath } from '@i18n/utils';
import { getCollectionByLang, getSlugFromId } from '@lib/collections';

const lang = 'en' as const;
const stories = await getCollectionByLang('stories', lang);

stories.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title={t(lang, 'nav.stories')}
  description="Community stories from queer Iraqis — shared anonymously and in their own words."
  lang={lang}
>
  <section class="py-8">
    <div class="flex items-baseline justify-between gap-4 flex-wrap mb-2">
      <h1 class="text-3xl font-bold">{t(lang, 'nav.stories')}</h1>
      <a
        href={localizedPath(lang, '/stories/submit')}
        class="text-sm bg-navy text-cream px-4 py-2 no-underline hover:bg-navy/90 font-semibold"
      >{t(lang, 'stories.submit.cta')} →</a>
    </div>
    <p class="text-muted mb-8">Voices from the community, shared anonymously and in their own words.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {stories.map((story) => (
        <Card
          title={story.data.title}
          description={story.data.description}
          href={localizedPath(lang, `/stories/${getSlugFromId(story.id)}`)}
          date={story.data.pubDate}
          lang={lang}
        />
      ))}
    </div>
  </section>
</BaseLayout>

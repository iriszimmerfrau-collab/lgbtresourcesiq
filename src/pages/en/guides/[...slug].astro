---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ArticleLayout from '@layouts/ArticleLayout.astro';
import GuideNav from '@components/GuideNav.astro';
import { getSlugFromId, estimateReadingTime } from '@lib/collections';
import {
  buildArticleSchema,
  buildMedicalWebPageSchema,
  buildLearningResourceSchema,
  buildBreadcrumbList,
  buildHowToSchema,
  buildFaqPageFromQuestions,
  combineSchemas,
  withSpeakable,
  estimateWordCount,
  type JsonLdContext,
  type ArticleEnrichment,
} from '@lib/jsonld';
import { guideEntityHints } from '@lib/entity-overlays';
import { localizedPath, t } from '@i18n/utils';

export async function getStaticPaths() {
  const guides = await getCollection('guides', (e: CollectionEntry<'guides'>) => e.data.lang === 'en' && !e.data.draft);
  return guides.map((guide) => ({
    params: { slug: getSlugFromId(guide.id) },
    props: { guide },
  }));
}

interface Props {
  guide: CollectionEntry<'guides'>;
}

const { guide } = Astro.props as Props;
const { Content, headings } = await render(guide);
const lang = 'en' as const;
const slug = getSlugFromId(guide.id);
const readingTime = estimateReadingTime(guide.body ?? '');
const wordCount = estimateWordCount(guide.body ?? '');

const siteUrl = new URL('/', Astro.site).href;
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const ctx: JsonLdContext = {
  lang,
  pageUrl,
  siteUrl,
  siteName: 'Iraqi Social Progress Collective',
};

const category = guide.data.category;
const isMedical = category === 'hrt' || category === 'mental-health';
const isEducational = category === 'identity' || category === 'general';

// Wikidata entity overlays live in @lib/entity-overlays so en/ar/ckb routes
// share identical hints. Language differs, but the underlying entities are
// universal. AI answer engines use these to disambiguate which Iraq, which
// estradiol, which gender dysphoria we mean.
const entityHints = guideEntityHints(slug);
const enrich: ArticleEnrichment = {
  about: entityHints.about,
  mentions: entityHints.mentions,
  wordCount,
  readingTime,
  citations: guide.data.citations,
};

const breadcrumbs = buildBreadcrumbList([
  { name: 'Home', url: new URL(localizedPath(lang, '/'), Astro.site).href },
  { name: t(lang, 'nav.guides'), url: new URL(localizedPath(lang, '/guides'), Astro.site).href },
  { name: t(lang, `guides.category.${category}` as any), url: new URL(localizedPath(lang, `/guides#${category}`), Astro.site).href },
  { name: guide.data.title, url: pageUrl },
]);

const primarySchema = isMedical
  ? buildMedicalWebPageSchema(guide, ctx, enrich)
  : isEducational
  ? buildLearningResourceSchema(guide, ctx, enrich)
  : buildArticleSchema(guide, ctx, enrich);

// Pharmacy script gets an extra HowTo schema with hand-authored steps
const pharmacyHowTo =
  slug === 'hrt-pharmacy-script'
    ? buildHowToSchema({
        name: 'How to ask an Iraqi pharmacy for hormone medication',
        description: 'Step-by-step harm-reduction approach for obtaining HRT medications at an Iraqi pharmacy without raising suspicion.',
        ctx,
        steps: [
          { name: 'Take a clear photo of the medication box', text: 'Have a clear, well-lit photo of the medication packaging ready on your phone before you walk into the pharmacy. Photographing the box of someone you trust who already has the medication is the cleanest source.' },
          { name: 'Walk into a private pharmacy alone', text: 'Choose a private pharmacy (not chain, not in your immediate neighborhood). Go alone. Confidence and brevity are your best cover.' },
          { name: 'Show the photo and name the medication', text: 'Show the pharmacist the photo on your phone. Say the brand name aloud (e.g. "Estrofem", "Androcur"). Do not explain why.' },
          { name: 'Have a cover story ready if asked', text: 'If asked what it is for, use the cover stories in our Pharmacy Script guide. Most pharmacists do not ask once they recognize the box.' },
          { name: 'If not in stock, ask for مذخر order', text: 'If the pharmacy does not stock it, ask them to order it from a مذخر (medical wholesaler). Most can deliver in 1-3 days. Pay a deposit if asked.' },
          { name: 'Rotate pharmacies for refills', text: 'Do not refill at the same pharmacy month after month. Spread purchases across 3-5 establishments so no single pharmacy sees your full pattern.' },
        ],
      })
    : null;

// Honor-violence guide's numbered escape plan is textbook HowTo material;
// surface it as structured data so AI engines extract it verbatim instead of
// paraphrasing a safety-critical sequence.
const escapePlanHowTo =
  slug === 'honor-violence'
    ? buildHowToSchema({
        name: 'Emergency escape plan for queer Iraqis facing imminent honor violence',
        description: 'Ordered safety steps for an Iraqi queer person whose family is about to confine or harm them. Action sequence. Do not wait for confirmation.',
        ctx,
        totalTime: 'PT1H',
        steps: [
          { name: 'Get out of the house', text: 'Leave with your documents and phone if you can. If forced to choose between safety and possessions, choose safety.' },
          { name: 'Leave the neighborhood', text: 'Take a taxi or bus to a location your family would not know to search. Pay in cash. Do not give the driver your real destination. Get out several streets early and walk the rest.' },
          { name: 'Contact your pre-arranged contact', text: 'Message or call the friend or community member you designated in advance. Tell them you are coming and roughly when.' },
          { name: 'Disable shared location services and family accounts', text: 'Many Iraqi families share Google or Apple accounts. Sign out. Disable Find My Phone. Revoke any shared device permissions.' },
          { name: 'Do not return home', text: 'Not "to grab something." Not "to explain." Once your family has decided, returning is what gets people killed.' },
          { name: 'Reach ISPC for next steps', text: 'Contact the ISPC community channel. We can help with next steps, long-term shelter referrals, and asylum information.' },
        ],
      })
    : null;

const articleFallback = isMedical || isEducational ? buildArticleSchema(guide, ctx, enrich) : null;

// Speakable wrapper marks the AnswerSummary block + H1 so voice assistants
// and AI engines that prefer speakable regions land on the front-loaded
// answer instead of an arbitrary middle paragraph.
const primaryWithSpeakable = guide.data.tldr ? withSpeakable(primarySchema as Record<string, unknown>) : primarySchema;

// Per-guide FAQPage schema. Paired 1:1 with the CommonQuestions block in
// the rendered HTML. AI engines extract these for related-query answers
// independent of the central site FAQ.
const faqPage =
  guide.data.commonQuestions?.length
    ? buildFaqPageFromQuestions(guide.data.commonQuestions, ctx)
    : null;

const jsonLd = combineSchemas(primaryWithSpeakable, articleFallback, pharmacyHowTo, escapePlanHowTo, faqPage, breadcrumbs);

const ogImage =
  category === 'hrt' || category === 'mental-health' ? '/og-hrt.png' : '/og-guide.png';

const article = {
  publishedTime: guide.data.pubDate.toISOString(),
  modifiedTime: guide.data.updatedDate?.toISOString(),
  section: category,
  tags: guide.data.keywords?.split(',').map((s) => s.trim()).filter(Boolean),
};

let relatedLinks: Array<{ title: string; url: string }> = [];
if (guide.data.relatedGuides?.length) {
  const allGuides = await getCollection('guides', (e: CollectionEntry<'guides'>) => e.data.lang === 'en' && !e.data.draft);
  const bySlug = new Map(allGuides.map((g) => [getSlugFromId(g.id), g]));
  relatedLinks = guide.data.relatedGuides
    .map((relSlug) => bySlug.get(relSlug))
    .filter((g): g is CollectionEntry<'guides'> => !!g)
    .map((g) => ({
      title: g.data.title,
      url: new URL(localizedPath(lang, `/guides/${getSlugFromId(g.id)}`), Astro.site).href,
    }));
}
---

<ArticleLayout
  title={guide.data.title}
  description={guide.data.description}
  lang={lang}
  pubDate={guide.data.pubDate}
  updatedDate={guide.data.updatedDate}
  readingTime={readingTime}
  jsonLd={jsonLd}
  keywords={guide.data.keywords}
  ogImage={ogImage}
  article={article}
  relatedLinks={relatedLinks}
  tldr={guide.data.tldr}
  commonQuestions={guide.data.commonQuestions}
  citations={guide.data.citations}
  editorialReviewedAt={isMedical ? (guide.data.updatedDate ?? guide.data.pubDate).toISOString().slice(0, 10) : undefined}
  headings={headings}
>
  <Content />
  {guide.data.parentGuide && (
    <GuideNav lang={lang} parentGuide={guide.data.parentGuide} currentSlug={slug} />
  )}
</ArticleLayout>

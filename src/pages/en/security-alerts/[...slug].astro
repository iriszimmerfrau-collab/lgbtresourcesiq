---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionDivider from '@components/SectionDivider.astro';
import AnswerSummary from '@components/AnswerSummary.astro';
import CommonQuestions from '@components/CommonQuestions.astro';
import Citations from '@components/Citations.astro';
import { t, localizedPath } from '@i18n/utils';
import { getSlugFromId, estimateReadingTime } from '@lib/collections';
import {
  buildAlertNewsArticleSchema,
  buildBreadcrumbList,
  buildFaqPageFromQuestions,
  combineSchemas,
  withSpeakable,
  estimateWordCount,
  type JsonLdContext,
  type ArticleEnrichment,
} from '@lib/jsonld';
import { alertEntityHints } from '@lib/entity-overlays';

export async function getStaticPaths() {
  const alerts = await getCollection('alerts', (e: CollectionEntry<'alerts'>) => e.data.lang === 'en' && !e.data.draft);
  return alerts.map((alert) => ({
    params: { slug: getSlugFromId(alert.id) },
    props: { alert },
  }));
}

interface Props {
  alert: CollectionEntry<'alerts'>;
}

const { alert } = Astro.props as Props;
const { Content } = await render(alert);
const lang = 'en' as const;
const readingTime = estimateReadingTime(alert.body ?? '');
const wordCount = estimateWordCount(alert.body ?? '');
const slug = getSlugFromId(alert.id);

const entityHints = alertEntityHints(slug);
const enrich: ArticleEnrichment = {
  about: entityHints.about,
  mentions: entityHints.mentions,
  wordCount,
  readingTime,
  citations: alert.data.citations,
};

const severityChrome: Record<string, string> = {
  critical: 'bg-exit-red text-white',
  high: 'bg-terracotta text-white',
  medium: 'bg-saffron text-navy',
  low: 'bg-lavender text-white',
  info: 'bg-navy/15 text-navy',
};

const siteUrl = new URL('/', Astro.site).href;
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const ctx: JsonLdContext = { lang, pageUrl, siteUrl, siteName: 'Iraqi Social Progress Collective' };

const newsSchema = buildAlertNewsArticleSchema(alert, ctx, enrich);
const newsWithSpeakable = alert.data.tldr ? withSpeakable(newsSchema as Record<string, unknown>) : newsSchema;
const faqPage =
  alert.data.commonQuestions?.length
    ? buildFaqPageFromQuestions(alert.data.commonQuestions, ctx)
    : null;
const jsonLd = combineSchemas(
  newsWithSpeakable,
  faqPage,
  buildBreadcrumbList([
    { name: 'Home', url: new URL(localizedPath(lang, '/'), Astro.site).href },
    { name: t(lang, 'alerts.title'), url: new URL(localizedPath(lang, '/security-alerts'), Astro.site).href },
    { name: alert.data.title, url: pageUrl },
  ]),
);

const ogImage =
  alert.data.severity === 'critical' || alert.data.severity === 'high'
    ? '/og-alert-critical.png'
    : '/og-alert-info.png';

const article = {
  publishedTime: alert.data.pubDate.toISOString(),
  section: alert.data.category,
  tags: alert.data.keywords?.split(',').map((s) => s.trim()).filter(Boolean),
};
---

<BaseLayout
  title={alert.data.title}
  description={alert.data.description}
  lang={lang}
  ogType="article"
  jsonLd={jsonLd}
  keywords={alert.data.keywords}
  articleWidth
  ogImage={ogImage}
  article={article}
>
  <article class="prose">
    <header class="mb-8">
      <SectionDivider />
      <p class="text-xs mb-3">
        <a href={localizedPath(lang, '/security-alerts')} class="text-muted no-underline hover:text-terracotta">← {t(lang, 'alerts.title')}</a>
      </p>
      <div class="flex items-center gap-2 flex-wrap mb-3 text-xs">
        <span class={`inline-block px-2.5 py-1 font-bold tracking-wider uppercase ${severityChrome[alert.data.severity]}`}>
          {t(lang, `alerts.severity.${alert.data.severity}` as any)}
        </span>
        <span class="text-muted font-mono uppercase tracking-wider">{t(lang, `alerts.category.${alert.data.category}` as any)}</span>
      </div>
      <h1>{alert.data.title}</h1>
      <div class="flex flex-wrap gap-4 text-sm text-muted mt-3">
        <time datetime={alert.data.pubDate.toISOString()}>
          {alert.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span>{readingTime} {t(lang, 'guides.readTime')}</span>
        {alert.data.affected && <span>{t(lang, 'alerts.label.affected')}: <strong class="text-body">{alert.data.affected}</strong></span>}
      </div>
    </header>

    {alert.data.tldr && <AnswerSummary text={alert.data.tldr} lang={lang} />}

    <Content />

    {alert.data.commonQuestions && alert.data.commonQuestions.length > 0 && (
      <CommonQuestions questions={alert.data.commonQuestions} lang={lang} />
    )}

    {alert.data.citations && alert.data.citations.length > 0 && (
      <Citations citations={alert.data.citations} lang={lang} />
    )}

    {alert.data.source && (
      <footer class="mt-12 pt-6 border-t border-muted/20 text-sm text-muted">
        <p>
          <strong>{t(lang, 'alerts.label.source')}:</strong>{' '}
          {alert.data.sourceUrl
            ? <a href={alert.data.sourceUrl} target="_blank" rel="noopener noreferrer">{alert.data.source} — {t(lang, 'alerts.label.original')}</a>
            : alert.data.source}
        </p>
      </footer>
    )}
  </article>
</BaseLayout>

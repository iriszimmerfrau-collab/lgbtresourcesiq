---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionDivider from '@components/SectionDivider.astro';
import AlertCard from '@components/AlertCard.astro';
import { t, localizedPath } from '@i18n/utils';
import { getCollectionByLang, getSlugFromId } from '@lib/collections';

const lang = 'en' as const;
const alerts = await getCollectionByLang('alerts', lang);

alerts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'LGBTQ+ Iraq Security Alerts',
  description: 'Verified LGBTQ+ news, security alerts, and risk advisories for Iraq.',
  inLanguage: 'en',
  isPartOf: {
    '@type': 'WebSite',
    name: 'Iraqi Social Progress Collective',
    url: 'https://ispc-iq.org/',
  },
  hasPart: alerts.slice(0, 20).map((a) => ({
    '@type': 'NewsArticle',
    headline: a.data.title,
    datePublished: a.data.pubDate.toISOString(),
    description: a.data.description,
  })),
};
---

<BaseLayout
  title={t(lang, 'alerts.title')}
  description="Verified LGBTQ+ Iraq news, security alerts, and risk advisories. Aggregated from Reuters, AP, BBC, Human Rights Watch, Outright International, Middle East Eye, and other sources. Reviewed before publication."
  lang={lang}
  jsonLd={jsonLd}
  keywords="LGBTQ Iraq news, Iraq security alerts LGBT, Iraq queer news, Iraq Law 14 2024, Iraq anti-LGBT law, queer Iraq danger, Iraq trans news, queer Iraq violence, militia attacks LGBT Iraq, Iraq airport phone search LGBTQ, Iraq queer asylum, Iraq border LGBT"
>
  <section class="py-8">
    <SectionDivider />
    <h1 class="text-3xl md:text-4xl font-bold mb-2">{t(lang, 'alerts.title')}</h1>
    <p class="text-lg text-muted leading-relaxed mb-3 max-w-3xl">{t(lang, 'alerts.subtitle')}</p>
    <p class="text-sm text-muted/80 mb-8 max-w-3xl">
      Sources we monitor: Reuters, AP, BBC, Al Jazeera English, Middle East Eye, Human Rights Watch, Amnesty International, Outright International, ILGA, Rainbow Railroad, IraqiNews, Rudaw, Kurdistan24, Pink News, Washington Blade, the Advocate, them., and Google News for "LGBTQ Iraq" and adjacent queries.
    </p>

    {alerts.length === 0 ? (
      <p class="text-muted py-12 text-center">{t(lang, 'alerts.empty')}</p>
    ) : (
      <>
        <div class="mb-6 flex flex-wrap gap-3 items-center">
          <input
            id="alerts-search"
            type="search"
            placeholder="Search by keyword, source, severity, category…"
            aria-label="Search alerts"
            class="flex-1 min-w-[16rem] p-3 border-2 border-navy/20 bg-white text-base focus:border-magenta focus:outline-none"
          />
          <select
            id="alerts-severity-filter"
            aria-label="Filter by severity"
            class="p-3 border-2 border-navy/20 bg-white text-sm"
          >
            <option value="">All severities</option>
            <option value="critical">Critical</option>
            <option value="high">High</option>
            <option value="medium">Medium</option>
            <option value="low">Low</option>
            <option value="info">Info</option>
          </select>
          <select
            id="alerts-category-filter"
            aria-label="Filter by category"
            class="p-3 border-2 border-navy/20 bg-white text-sm"
          >
            <option value="">All categories</option>
            <option value="legal">Legal</option>
            <option value="violence">Violence</option>
            <option value="surveillance">Surveillance</option>
            <option value="border">Border / travel</option>
            <option value="community">Community</option>
            <option value="news">News</option>
            <option value="asylum">Asylum</option>
          </select>
        </div>
        <p id="alerts-result-count" class="text-sm text-muted mb-4">{alerts.length} alerts</p>
        <div id="alerts-grid" class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {alerts.map((alert) => (
            <div
              class="alerts-item"
              data-search={`${alert.data.title} ${alert.data.description} ${alert.data.source ?? ''} ${alert.data.affected ?? ''} ${alert.data.keywords ?? ''}`.toLowerCase()}
              data-severity={alert.data.severity}
              data-category={alert.data.category}
            >
              <AlertCard
                alert={alert}
                href={localizedPath(lang, `/security-alerts/${getSlugFromId(alert.id)}`)}
                lang={lang}
              />
            </div>
          ))}
        </div>
        <p id="alerts-empty-search" class="hidden text-muted py-12 text-center">No alerts match your search.</p>
      </>
    )}
  </section>

  <script is:inline>
    (function () {
      var input = document.getElementById('alerts-search');
      var sevSel = document.getElementById('alerts-severity-filter');
      var catSel = document.getElementById('alerts-category-filter');
      var grid = document.getElementById('alerts-grid');
      var emptyMsg = document.getElementById('alerts-empty-search');
      var counter = document.getElementById('alerts-result-count');
      if (!input || !grid) return;
      var items = grid.querySelectorAll('.alerts-item');
      var totalCount = items.length;

      function apply() {
        var q = (input.value || '').trim().toLowerCase();
        var sev = (sevSel && sevSel.value) || '';
        var cat = (catSel && catSel.value) || '';
        var visible = 0;
        items.forEach(function (el) {
          var hay = el.getAttribute('data-search') || '';
          var elSev = el.getAttribute('data-severity') || '';
          var elCat = el.getAttribute('data-category') || '';
          var match = (q === '' || hay.indexOf(q) !== -1)
            && (sev === '' || elSev === sev)
            && (cat === '' || elCat === cat);
          el.style.display = match ? '' : 'none';
          if (match) visible++;
        });
        if (counter) {
          counter.textContent = visible === totalCount
            ? TotalCount + ' alerts'
            : visible + ' of ' + totalCount + ' alerts';
        }
        if (emptyMsg) emptyMsg.classList.toggle('hidden', visible !== 0);
        grid.classList.toggle('hidden', visible === 0);
      }
      input.addEventListener('input', apply);
      if (sevSel) sevSel.addEventListener('change', apply);
      if (catSel) catSel.addEventListener('change', apply);
    })();
  </script>
</BaseLayout>

---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionDivider from '@components/SectionDivider.astro';
import { localizedPath } from '@i18n/utils';

const lang = 'ar' as const;

const faqs = [
  {
    q: 'هل المثلية والتحول الجنسي ممنوعان قانونياً في العراق؟',
    a: 'نعم. في نيسان 2024، أقرّ البرلمان العراقي القانون رقم 14. "قانون مكافحة البغاء والمثلية الجنسية". الذي يعاقب على العلاقات المثلية بالسجن من 10 إلى 15 سنة، و"الترويج للمثلية" بالسجن حتى 7 سنوات، والتحول الجنسي بالسجن حتى 3 سنوات. قبل القانون كانت الملاحقات تستند إلى مواد فضفاضة عن الآداب العامة. التطبيق غير منتظم لكنه حقيقي. إقليم كردستان العراق يمنح هامشاً نظرياً أوسع قليلاً لكنه يخضع لذات القانون الاتحادي.',
  },
  {
    q: 'كيف أعرف إن كنت مثلياً، مثلية، مزدوج/ة الجنس، أو متحول/ة جنسياً؟',
    a: 'لا يوجد اختبار. إن شعرت بانجذاب إلى أشخاص من نفس جنسك، فقد تكون مثلياً، مثلية، مزدوج/ة الجنس، أو بانسكشوال. وإن كان إحساسك بنفسك كرجل أو امرأة أو كليهما أو لا شيء منهما لا يطابق ما حُدّد لك عند الولادة، فقد تكون متحولاً/ة جنسياً أو خارج الثنائية. كثير من العراقيين يقضون سنوات في الحيرة لأن اللغة والمفاهيم لم تُتَح لهم أصلاً. الحيرة ليست فشلاً. هي بداية الفهم. أدلتنا حول الهوية والصحة النفسية تساعدك على بناء مفرداتك الخاصة.',
  },
  {
    q: 'كيف أحصل على الهرمونات (العلاج الهرموني) في العراق؟',
    a: 'لدينا إرشادات حول الوصول إلى HRT في العراق. يرجى التواصل معنا عبر القناة الآمنة لمزيد من المعلومات. اقرأ [دليل الحصول على الهرمونات في العراق](/ar/guides/hrt-sourcing-iraq) و[نص الصيدلية](/ar/guides/hrt-pharmacy-script).',
  },
  {
    q: 'هل من الآمن البدء بالعلاج الهرموني بدون طبيب؟',
    a: 'الإشراف الطبي المثالي نادراً ما يكون متاحاً للعراقيين الكويريين. أدلتنا تنطلق من مبدأ تقليل الأضرار: إن كنت ستبدأ على أي حال، إليك كيف تفعل ذلك بأكبر قدر ممكن من الأمان. وثّقنا الجرعات القياسية، التحاليل المطلوبة (E2، T، البرولاكتين، إنزيمات الكبد، البوتاسيوم، الدهون)، والعلامات التحذيرية التي تستوجب التوقف أو طلب الرعاية. المختبرات الخاصة في العراق تجري هذه التحاليل بـ 25,000-60,000 دينار بدون أسئلة. اقرأ [مخاطر العلاج الهرموني](/ar/guides/hrt-risks) و[المراقبة المختبرية](/ar/guides/hrt-monitoring) قبل البدء.',
  },
  {
    q: 'ما هي الطريقة الأكثر أماناً للتواصل مع عراقيين كويريين آخرين على الإنترنت؟',
    a: 'نوصي ببروتوكول XMPP مع تشفير OMEMO، باستخدام تطبيق Conversations (أندرويد، مجاني من F-Droid) أو Monal (آيفون). XMPP لا يتطلب رقم هاتف، لامركزي، ومشفّر من طرف إلى طرف. واتساب وتلغرام كلاهما يعاني من ثغرات تتعلق بنموذج التهديد الذي نواجهه. حسابات مرتبطة برقم الهاتف، تسريب بيانات وصفية، وإمكانية الاعتراض القانوني. [صفحة المجتمع](/ar/community) تشرح خطوات الإعداد. استخدم VPN في نفس الوقت.',
  },
  {
    q: 'ما هو أفضل VPN في العراق؟',
    a: 'Mullvad و ProtonVPN هما الخياران الأكثر ثقة (مجاناً أو مدفوعاً). كلاهما يقبل الدفع المجهول، لا يطلب بريداً إلكترونياً، وسياسة عدم الاحتفاظ بالسجلات لديهما خضعت لتدقيق مستقل. تجنب تطبيقات VPN المجانية من متجر Play. معظمها واجهات للمراقبة. على الموبايل، ثبّت من F-Droid أو من موقع المزود مباشرةً، وليس عبر حساب Google مرتبط بهويتك الحقيقية.',
  },
  {
    q: 'كيف أحذف سجل المتصفح بسرعة إذا كان أحدهم على وشك فحص هاتفي؟',
    a: 'على Chrome للأندرويد: الإعدادات → الخصوصية والأمان → مسح بيانات التصفح → "كل الوقت" → علّم على السجل، الكوكيز، والذاكرة المؤقتة. على Samsung Internet: الإعدادات → بيانات التصفح الشخصية → حذف بيانات التصفح. على Firefox للأندرويد: انقر قائمة النقاط الثلاث → السجل → حذف بيانات التصفح. العادة الأسرع هي استخدام الوضع الخاص/التصفح المتخفي لكل ما يخص الكويرنس، حتى لا يكون هناك ما يُمسح. أيضاً: في كل صفحة من هذا الموقع زر خروج سريع (أعلى اليمين) ومفتاح ESC ينفّذه فوراً.',
  },
  {
    q: 'هل يمكنني طلب اللجوء خارج العراق لأنني من مجتمع الميم؟',
    a: 'نعم. الميل الجنسي والهوية الجندرية أسس معترف بها لمنح صفة اللاجئ بموجب اتفاقية اللاجئين 1951. عراقيون من مجتمع الميم حصلوا على اللجوء في ألمانيا وكندا وأمريكا وهولندا وغيرها. المسار الأكثر شيوعاً هو مغادرة العراق أولاً (غالباً عبر تركيا أو لبنان)، التسجيل لدى المفوضية الأممية لشؤون اللاجئين (UNHCR)، وطلب إعادة التوطين. منظمة Rainbow Railroad تساعد في الحالات القصوى. العملية تستغرق سنوات وغير مضمونة. نتعامل مع اللجوء كخيار حقيقي، لا كحلم ولا كحل سريع.',
  },
  {
    q: 'عائلتي تشكّ بأني مثلي/ة أو متحول/ة. ماذا أفعل؟',
    a: 'أولويتك الفورية هي السلامة الجسدية. إن كنت تعيش/ين مع عائلتك والشكوك تتصاعد، حضّر/ي حقيبة طوارئ: هوية، نقود، هاتف، شاحن، ملابس بديلة، قائمة بأشخاص يستطيعون استضافتك ليلة واحدة. انقل المحتوى الحساس بعيداً عن الأجهزة المشتركة وعن حسابات السحابة التي يمكن لعائلتك الوصول إليها. لا تؤكد ما لست مستعداً/ة لتأكيده. جرائم الشرف حقيقية وتطال العراقيين الكويريين بشكل غير متناسب. اقرأ [دليل العنف باسم الشرف](/ar/guides/honor-violence) للتخطيط للسلامة.',
  },
  {
    q: 'هل يوجد معالج نفسي صديق لمجتمع الميم في العراق؟',
    a: 'لا يوجد تقريباً معالجون مؤكِّدون لمجتمع الميم يعملون علناً في العراق بسبب المخاطر القانونية عليهم. عدد قليل من الأخصائيين النفسيين الأصغر سناً في بغداد وأربيل يعملون بهدوء مع عملاء/عميلات من مجتمع الميم لكنهم لا يعلنون ذلك. خيارات أونلاين تقبل العملاء العراقيين الناطقين بالعربية تشمل معالجين عبر Shezlong وLabayh وMeditopia. للدعم في الأزمات مجاناً، تواصل معنا. لدينا قائمة موثّقة من الموارد المتحقَّق منها.',
  },
  {
    q: 'كيف أجد مجتمعاً كويرياً في بغداد، أربيل، أو البصرة؟',
    a: 'لا يوجد مكان عام، منظمة، أو نادٍ كويري يعمل علناً في أي مكان في العراق. صار ذلك مستحيلاً بعد قانون 2024. المجتمع يحدث في مجموعات دردشة مشفّرة، تجمعات خاصة صغيرة، وتعارفات شخصية موثوقة. الطريقة الأكثر موثوقية للانخراط هي مراسلتنا على XMPP (`iriszimmerfrau@conversations.im`). لن نضغط عليك، لن نسأل عن اسمك الحقيقي، وأحياناً نستطيع تزكيتك للدخول إلى مجموعة دردشة بعد أن نتعرف عليك. أربيل والسليمانية فيهما هامش تحت الأرض أوسع قليلاً من بغداد أو الجنوب.',
  },
  {
    q: 'لدي أفكار انتحارية. ماذا أفعل الآن؟',
    a: 'لست وحدك، ولست مكسوراً/ة. الألم الذي تشعر/ين به هو رد فعل على ظروف ستسحق أي شخص تقريباً. أرجوك تواصل/ي معنا. راسلنا على XMPP `iriszimmerfrau@conversations.im` أو بالبريد `iriszimmerfrau@proton.me`. لن نبلّغ عنك، لن نحكم عليك، لن ندفعك. إن استطعت، اجلس/ي مع أحدهم الليلة، حتى لو كان غريباً على الإنترنت، حتى لا تكون/ين وحدك في الساعات الأصعب. الغد لم يُحلّ، لكن الغد ممكن.',
  },
  {
    q: 'هل زيارة هذا الموقع آمنة؟ هل تستطيع الحكومة معرفة أني كنت هنا؟',
    a: 'لا نسجّل عناوين IP، لا نضع كوكيز للتتبع، ولا نستخدم متتبّعين من جهات خارجية. الموقع لا يحمّل أي موارد خارجية إلا اختيارياً Plausible Analytics. وفقط إذا منحت موافقتك صراحةً. مع ذلك، يستطيع مزوّد الإنترنت لديك رؤية أنك زرت النطاق. استخدم VPN. استخدم التصفح الخاص. اضغط ESC في أي وقت على الموقع لتُحوَّل إلى Google فوراً. اقرأ [السلامة](/ar/safety) و[الخصوصية](/ar/privacy) للتفاصيل.',
  },
  {
    q: 'هل أنتم منظمة خيرية أو غير حكومية؟ من يموّلكم؟',
    a: 'لا. نحن تجمّع تكافلي بين الأقران. لسنا مسجّلين كجمعية أو منظمة غير حكومية، لا نتلقى منحاً، ولسنا تابعين لأي حكومة أو حزب سياسي أو منظمة أجنبية. تكاليف التشغيل (النطاق، الخادم) يغطّيها أعضاء المجتمع. نرفض أي تمويل قد يهدد استقلاليتنا أو يعرّض المساهمين للخطر.',
  },
  {
    q: 'هل أستطيع المساهمة بقصة أو دليل بدون الكشف عن هويتي؟',
    a: 'نعم. ونشجّعك بشدة على ذلك. أنشئ حساب XMPP باسم مستعار لا يدل عليك، راسلنا، وسنعمل معك على النشر. لا ننشر أبداً بدون موافقتك الصريحة وننزع أي تفاصيل قد تكشف عنك قبل النشر. اقرأ [كيف تشارك قصتك](/ar/community#anonymous-contribution).',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: 'ar',
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.prose h2', '.prose p'],
  },
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: a.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '$1'),
    },
  })),
};
---

<BaseLayout
  title="الأسئلة الشائعة. أسئلة العراقيين الكويريين"
  description="إجابات على أسئلة يطرحها العراقيون الكويريون: الحصول على الهرمونات، قانون مكافحة المثلية 2024، الأمان الرقمي، اللجوء، الصحة النفسية، وإيجاد المجتمع في بغداد وأربيل والبصرة وكردستان العراق."
  lang={lang}
  articleWidth
  jsonLd={jsonLd}
  keywords="أسئلة العراقيين الكويريين, مثليين العراق, متحولين العراق, هرمونات العراق, قانون مكافحة المثلية, لجوء مثليين العراق, كوير بغداد, كوير أربيل, كوير كردستان"
>
  <section class="prose">
    <SectionDivider />
    <h1>الأسئلة الشائعة</h1>

    <p>
      أسئلة حقيقية يطرحها عراقيون كويريون. الإجابات مكتوبة بلغة بسيطة، مع روابط إلى أدلة أعمق
      عند الحاجة. إن لم يكن سؤالك هنا، اكتب لنا. راجع <a href={localizedPath(lang, '/community')}>صفحة المجتمع</a>.
    </p>

    <hr />

    {faqs.map(({ q, a }) => (
      <article class="mb-8">
        <h2 class="text-xl font-bold mb-2">{q}</h2>
        <p set:html={a.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>').replace(/`([^`]+)`/g, '<code>$1</code>')} />
      </article>
    ))}
  </section>
</BaseLayout>

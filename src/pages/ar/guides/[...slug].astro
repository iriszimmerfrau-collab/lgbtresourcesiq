---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ArticleLayout from '@layouts/ArticleLayout.astro';
import GuideNav from '@components/GuideNav.astro';
import { getSlugFromId, estimateReadingTime } from '@lib/collections';
import {
  buildArticleSchema,
  buildMedicalWebPageSchema,
  buildLearningResourceSchema,
  buildBreadcrumbList,
  buildHowToSchema,
  combineSchemas,
  type JsonLdContext,
} from '@lib/jsonld';
import { localizedPath, t } from '@i18n/utils';

export async function getStaticPaths() {
  const guides = await getCollection('guides', (e: CollectionEntry<'guides'>) => e.data.lang === 'ar' && !e.data.draft);
  return guides.map((guide) => ({
    params: { slug: getSlugFromId(guide.id) },
    props: { guide },
  }));
}

interface Props {
  guide: CollectionEntry<'guides'>;
}

const { guide } = Astro.props as Props;
const { Content } = await render(guide);
const lang = 'ar' as const;
const slug = getSlugFromId(guide.id);
const readingTime = estimateReadingTime(guide.body ?? '');

const siteUrl = new URL('/', Astro.site).href;
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const ctx: JsonLdContext = {
  lang,
  pageUrl,
  siteUrl,
  siteName: 'التجمع العراقي للتقدم الاجتماعي',
};

const category = guide.data.category;
const isMedical = category === 'hrt' || category === 'mental-health';
const isEducational = category === 'identity' || category === 'general';

const breadcrumbs = buildBreadcrumbList([
  { name: t(lang, 'nav.home'), url: new URL(localizedPath(lang, '/'), Astro.site).href },
  { name: t(lang, 'nav.guides'), url: new URL(localizedPath(lang, '/guides'), Astro.site).href },
  { name: t(lang, `guides.category.${category}` as any), url: new URL(localizedPath(lang, `/guides#${category}`), Astro.site).href },
  { name: guide.data.title, url: pageUrl },
]);

const primarySchema = isMedical
  ? buildMedicalWebPageSchema(guide, ctx)
  : isEducational
  ? buildLearningResourceSchema(guide, ctx)
  : buildArticleSchema(guide, ctx);

const howToSchema =
  slug === 'hrt-pharmacy-script'
    ? buildHowToSchema({
        name: 'كيف تطلب الهرمونات من صيدلية عراقية',
        description: 'خطوات عملية للحصول على أدوية العلاج الهرموني من الصيدليات العراقية بأقل قدر من الانكشاف.',
        ctx,
        steps: [
          { name: 'حضّر صورة واضحة لعلبة الدواء', text: 'تأكد من أن لديك صورة واضحة لعلبة الدواء على هاتفك قبل دخول الصيدلية.' },
          { name: 'ادخل صيدلية خاصة بمفردك', text: 'اختر صيدلية خاصة ليست في حيك المباشر. اذهب بمفردك. الثقة والإيجاز أفضل غطاء.' },
          { name: 'أرِ الصورة وقل الاسم التجاري', text: 'أرِ الصيدلي الصورة على هاتفك. قل الاسم التجاري بصوت طبيعي (مثلاً "Estrofem" أو "Androcur"). لا تشرح لماذا.' },
          { name: 'احتفظ بقصة غطاء إن سُئلت', text: 'إن سُئلت لماذا، استخدم قصص الغطاء في دليل نص الصيدلية. أغلب الصيادلة لا يسألون بعد أن يتعرفوا على العلبة.' },
          { name: 'إن لم يكن متوفراً، اطلب من المذخر', text: 'إن لم يتوفر، اطلب من الصيدلي أن يطلبه من مذخر. غالباً يصل خلال 1–3 أيام. ادفع عربون إن طُلب.' },
          { name: 'نوّع الصيدليات في الشهور التالية', text: 'لا تعد لنفس الصيدلية شهراً بعد شهر. وزّع الشراء على 3–5 محلات حتى لا ترى صيدلية واحدة نمطك الكامل.' },
        ],
      })
    : null;

const articleFallback =
  isMedical || isEducational ? buildArticleSchema(guide, ctx) : null;

const jsonLd = combineSchemas(primarySchema, articleFallback, howToSchema, breadcrumbs);

const ogImage =
  category === 'hrt' || category === 'mental-health' ? '/og-hrt.png' : '/og-guide.png';

const article = {
  publishedTime: guide.data.pubDate.toISOString(),
  modifiedTime: guide.data.updatedDate?.toISOString(),
  section: category,
  tags: guide.data.keywords?.split(',').map((s) => s.trim()).filter(Boolean),
};

let relatedLinks: Array<{ title: string; url: string }> = [];
if (guide.data.relatedGuides?.length) {
  const allGuides = await getCollection('guides', (e: CollectionEntry<'guides'>) => e.data.lang === 'ar' && !e.data.draft);
  const bySlug = new Map(allGuides.map((g) => [getSlugFromId(g.id), g]));
  relatedLinks = guide.data.relatedGuides
    .map((relSlug) => bySlug.get(relSlug))
    .filter((g): g is CollectionEntry<'guides'> => !!g)
    .map((g) => ({
      title: g.data.title,
      url: new URL(localizedPath(lang, `/guides/${getSlugFromId(g.id)}`), Astro.site).href,
    }));
}
---

<ArticleLayout
  title={guide.data.title}
  description={guide.data.description}
  lang={lang}
  pubDate={guide.data.pubDate}
  updatedDate={guide.data.updatedDate}
  readingTime={readingTime}
  jsonLd={jsonLd}
  keywords={guide.data.keywords}
  ogImage={ogImage}
  article={article}
  relatedLinks={relatedLinks}
>
  <Content />
  {guide.data.parentGuide && (
    <GuideNav lang={lang} parentGuide={guide.data.parentGuide} currentSlug={slug} />
  )}
</ArticleLayout>

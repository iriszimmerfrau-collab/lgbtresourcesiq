---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ArticleLayout from '@layouts/ArticleLayout.astro';
import { estimateReadingTime, getSlugFromId } from '@lib/collections';
import { buildArticleSchema, buildBreadcrumbList, combineSchemas, type JsonLdContext } from '@lib/jsonld';
import { localizedPath, t } from '@i18n/utils';

export async function getStaticPaths() {
  const news = await getCollection('news', (e: CollectionEntry<'news'>) => e.data.lang === 'ar' && !e.data.draft);
  return news.map((item) => ({
    params: { slug: getSlugFromId(item.id) },
    props: { item },
  }));
}

interface Props {
  item: CollectionEntry<'news'>;
}

const { item } = Astro.props as Props;
const { Content } = await render(item);
const lang = 'ar' as const;
const readingTime = estimateReadingTime(item.body ?? '');

const siteUrl = new URL('/', Astro.site).href;
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const ctx: JsonLdContext = { lang, pageUrl, siteUrl, siteName: 'التجمع العراقي للتقدم الاجتماعي' };

const jsonLd = combineSchemas(
  buildArticleSchema(item, ctx),
  buildBreadcrumbList([
    { name: t(lang, 'nav.home'), url: new URL(localizedPath(lang, '/'), Astro.site).href },
    { name: t(lang, 'nav.news'), url: new URL(localizedPath(lang, '/news'), Astro.site).href },
    { name: item.data.title, url: pageUrl },
  ]),
);

const article = {
  publishedTime: item.data.pubDate.toISOString(),
  section: 'news',
  tags: item.data.keywords?.split(',').map((s) => s.trim()).filter(Boolean),
};
---

<ArticleLayout
  title={item.data.title}
  description={item.data.description}
  lang={lang}
  pubDate={item.data.pubDate}
  readingTime={readingTime}
  jsonLd={jsonLd}
  keywords={item.data.keywords}
  ogImage="/og-guide.png"
  article={article}
>
  <Content />
  {item.data.source && (
    <footer class="mt-12 pt-6 border-t border-muted/20 text-sm text-muted">
      <p>
        <strong>المصدر:</strong>{' '}
        {item.data.sourceUrl
          ? <a href={item.data.sourceUrl} target="_blank" rel="noopener noreferrer">{item.data.source}</a>
          : item.data.source}
      </p>
    </footer>
  )}
</ArticleLayout>

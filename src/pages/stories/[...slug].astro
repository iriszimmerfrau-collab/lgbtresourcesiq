---
/**
 * Unified story detail page. Single canonical URL per story regardless of
 * the visitor's site language. The page chrome renders in the story's
 * own authored language so the reading experience is consistent.
 */
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ArticleLayout from '@layouts/ArticleLayout.astro';
import Callout from '@components/Callout.astro';
import { estimateReadingTime, getSlugFromId } from '@lib/collections';
import { t } from '@i18n/utils';
import type { Lang } from '@i18n/languages';
import {
  buildArticleSchema,
  buildBreadcrumbList,
  buildPersonSchema,
  combineSchemas,
  estimateWordCount,
  withSpeakable,
  type JsonLdContext,
  type ArticleEnrichment,
} from '@lib/jsonld';

export async function getStaticPaths() {
  const stories = await getCollection('stories', (e: CollectionEntry<'stories'>) => !e.data.draft);
  return stories.map((story) => ({
    params: { slug: getSlugFromId(story.id) },
    props: { story },
  }));
}

interface Props {
  story: CollectionEntry<'stories'>;
}

const { story } = Astro.props as Props;
const { Content } = await render(story);
const lang: Lang = (story.data.lang ?? 'en') as Lang;
const readingTime = estimateReadingTime(story.body ?? '');
const wordCount = estimateWordCount(story.body ?? '');
const enrich: ArticleEnrichment = { wordCount, readingTime };

const byline = story.data.anonymous
  ? T(lang, 'stories.anonymous')
  : (story.data.pseudonym ?? T(lang, 'stories.anonymous'));

const siteUrl = new URL('/', Astro.site).href;
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const siteName =
  lang === 'ar' ? 'التجمع العراقي للتقدم الاجتماعي' :
  lang === 'ckb' ? 'کۆڕی پێشکەوتنی کۆمەڵایەتیی عێراق' :
  'Iraqi Social Progress Collective';
const ctx: JsonLdContext = { lang, pageUrl, siteUrl, siteName };

const baseArticle = buildArticleSchema(story as unknown as CollectionEntry<'news'>, ctx, enrich) as Record<string, unknown>;
const articleSchema = {
  ...baseArticle,
  author: buildPersonSchema(story, ctx),
};
const articleWithSpeakable = story.data.tldr ? withSpeakable(articleSchema) : articleSchema;

const storiesLabel =
  lang === 'ar' ? 'القصص' : lang === 'ckb' ? 'چیرۆکەکان' : 'Stories';
const homeLabel =
  lang === 'ar' ? 'الرئيسية' : lang === 'ckb' ? 'سەرەکی' : 'Home';

// Breadcrumb back-link points at the lang-specific listing surface so a
// reader returning from the story stays in the chrome they started in.
const storiesListingUrl = new URL(`/${lang}/stories/`, Astro.site).href;
const homeUrl = new URL(`/${lang}/`, Astro.site).href;

const jsonLd = combineSchemas(
  articleWithSpeakable,
  buildBreadcrumbList([
    { name: homeLabel, url: homeUrl },
    { name: storiesLabel, url: storiesListingUrl },
    { name: story.data.title, url: pageUrl },
  ]),
);

const article = {
  publishedTime: story.data.pubDate.toISOString(),
  section: 'stories',
  tags: story.data.keywords?.split(',').map((s) => s.trim()).filter(Boolean),
};

const cwLabel =
  lang === 'ar' ? 'تحذير المحتوى' : lang === 'ckb' ? 'ئاگاداریی ناوەڕۆک' : 'Content warning';
---

<ArticleLayout
  title={story.data.title}
  description={story.data.description}
  lang={lang}
  pubDate={story.data.pubDate}
  readingTime={readingTime}
  jsonLd={jsonLd}
  keywords={story.data.keywords}
  ogImage="/og-story.png"
  article={article}
  tldr={story.data.tldr}
>
  {story.data.contentWarning && (
    <Callout type="warning">
      <strong>{cwLabel}:</strong> {story.data.contentWarning}
    </Callout>
  )}
  <p class="text-sm text-muted italic mb-6">,  {byline}</p>
  <Content />
</ArticleLayout>

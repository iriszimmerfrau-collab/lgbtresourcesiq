---
/**
 * AnswerSummary — front-loaded answer block rendered at the top of guides,
 * stories, and alerts when frontmatter declares a `tldr`.
 *
 * GEO / AEO purpose: AI answer engines (Perplexity, Google AI Overview,
 * ChatGPT Search, Claude.ai) extract the first concrete answer they find on
 * a page. Articles that lead with a 1-3 sentence direct answer get cited
 * verbatim; articles that lead with context don't. The `data-speakable`
 * attribute is the hook our Schema.org SpeakableSpecification targets, so
 * voice assistants and AI engines that prefer speakable regions land here.
 *
 * Visually understated by design — a left-rule callout in cream-on-navy
 * that reads like an answer, not like marketing. Keeps the "looks like an
 * article" threat-model property intact.
 */
import type { Lang } from '@i18n/languages';

interface Props {
  /** The answer text. Plain prose, 1-3 sentences. */
  text: string;
  /** Page language (drives label translation). */
  lang: Lang;
}

const { text, lang } = Astro.props;

const label =
  lang === 'ar' ? 'الإجابة باختصار' : lang === 'ckb' ? 'وەڵامەکە بە کورتی' : 'In short';
---

<aside
  class="not-prose mb-8 border-s-4 border-magenta bg-cream/40 ps-5 pe-4 py-4"
  role="note"
  aria-label={label}
  data-speakable="answer-summary"
>
  <p class="text-xs font-bold uppercase tracking-widest text-magenta mb-2">{label}</p>
  <p class="text-base text-navy leading-relaxed font-medium m-0">{text}</p>
</aside>

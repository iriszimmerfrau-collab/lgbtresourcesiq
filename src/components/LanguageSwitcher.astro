---
import type { Lang } from '@i18n/languages';
import { languages } from '@i18n/languages';
import { switchLangPath, getOtherLangs } from '@i18n/utils';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const others = getOtherLangs(lang);
---

<div class="flex items-center gap-2 text-sm text-cream/80" aria-label="Choose language">
  {others.map((target, i) => (
    <>
      {i > 0 && <span class="text-cream/30" aria-hidden="true">·</span>}
      <a
        href={switchLangPath(currentPath, target)}
        lang={target}
        class="text-cream hover:text-white no-underline font-semibold tracking-wide transition-colors"
      >
        {languages[target]}
      </a>
    </>
  ))}
</div>

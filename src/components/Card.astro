---
interface Props {
  title: string;
  description: string;
  href: string;
  date?: Date;
  lang?: string;
}

const { title, description, href, date, lang = 'en' } = Astro.props;
---

<a href={href} class="block no-underline group">
  <div class="bg-white border border-muted/10 rounded p-5 transition-transform duration-200 group-hover:-translate-y-0.5">
    <h3 class="text-lg font-bold text-navy mb-2 group-hover:text-terracotta transition-colors">{title}</h3>
    <p class="text-muted text-sm leading-relaxed mb-3">{description}</p>
    {date && (
      <time class="text-xs text-muted/60" datetime={date.toISOString()}>
        {date.toLocaleDateString(lang === 'ar' ? 'ar-IQ' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    )}
  </div>
</a>

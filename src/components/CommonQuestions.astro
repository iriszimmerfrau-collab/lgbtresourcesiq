---
/**
 * CommonQuestions. Per-guide Q&A accordion rendered above the related-links
 * footer when frontmatter declares `commonQuestions`. Native HTML
 * <details>/<summary> elements. No JavaScript, no client hydration, CSP-safe.
 *
 * GEO / AEO purpose: AI engines and "people also ask" search features
 * extract these Q&A pairs verbatim when paired with the FAQPage JSON-LD
 * schema the route template emits. Pairs are scoped per-page so each
 * guide answers the questions a reader of that specific page would ask,
 * not a generic site FAQ.
 *
 * The summary line is the question; the body is the answer. Each pair gets
 * `data-speakable` so voice / AI engines that prefer speakable regions
 * can also land here.
 */
import type { Lang } from '@i18n/languages';

interface Question {
  q: string;
  a: string;
}

interface Props {
  questions: Question[];
  lang: Lang;
}

const { questions, lang } = Astro.props;

const heading =
  lang === 'ar' ? 'أسئلة شائعة عن هذا الدليل' :
  lang === 'ckb' ? 'پرسیارە باوەکان دەربارەی ئەم ڕێبەرە' :
  'Common questions';
---

<section
  class="not-prose mt-12 pt-8 border-t-2 border-magenta/20"
  aria-labelledby="common-questions-heading"
>
  <h2
    id="common-questions-heading"
    class="text-xs font-bold uppercase tracking-widest text-muted mb-4"
  >
    {heading}
  </h2>
  <div class="space-y-2">
    {questions.map((qa) => (
      <details class="border border-navy/15 bg-cream/30 group">
        <summary
          class="cursor-pointer px-4 py-3 font-semibold text-navy hover:bg-cream/60 list-none flex justify-between items-start gap-3"
          data-speakable="question"
        >
          <span class="flex-1">{qa.q}</span>
          <span class="text-magenta font-mono shrink-0 transition-transform group-open:rotate-45" aria-hidden="true">+</span>
        </summary>
        <div
          class="px-4 pb-4 pt-2 text-body leading-relaxed border-t border-navy/10"
          data-speakable="answer"
          set:html={qa.a.replace(/\n/g, '<br>')}
        ></div>
      </details>
    ))}
  </div>
</section>

---
/**
 * Sorani-language stub page. Used as a fallback for CKB URLs whose
 * content has not yet been translated. Renders a clear notice in
 * Sorani that the page is being translated and links to the
 * Arabic original (most Sorani readers in Iraq are also Arabic-literate).
 *
 * Embeds inside BaseLayout with `noindex` + `canonicalOverride` set so
 * search engines treat the AR page as authoritative and skip indexing
 * the near-duplicate CKB stub.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionDivider from '@components/SectionDivider.astro';

interface Props {
  /** Page title in Sorani (e.g. 'سەرەکی') */
  title: string;
  /** Where to link the reader for the Arabic original (path or full URL) */
  arHref: string;
  /** Optional short label describing the page type, e.g. 'پەڕەی سەرەکی' */
  pageLabel?: string;
}

const { title, arHref, pageLabel } = Astro.props;
const canonicalArUrl = arHref.startsWith('http') ? arHref : new URL(arHref, Astro.site).href;
const description = 'وەرگێڕانی کوردیی ئەم پەڕەیە لە ژێر ئامادەکاریدایە. تکایە نوسخەی عەرەبیی بخوێنەرەوە.';
---

<BaseLayout
  title={title}
  description={description}
  lang="ckb"
  articleWidth
  noindex={true}
  canonicalOverride={canonicalArUrl}
>
  <section class="prose">
    <SectionDivider />
    <h1>{title}</h1>
    {pageLabel && <p class="text-sm text-muted font-mono uppercase tracking-wider">{pageLabel}</p>}

    <div class="my-8 p-6 border-2 border-magenta/30 bg-magenta/5">
      <p class="text-lg font-bold text-navy mb-3">
        ئەم پەڕە بە کوردی هێشتا ئامادە نییە
      </p>
      <p class="text-base leading-relaxed mb-3">
        ئێمە لە سەر ئامادەکردنی وەرگێڕانی کوردیی هەموو ناوەڕۆکی ماڵپەڕەکەین.
        تا ئەو کاتە، تکایە نوسخەی عەرەبی بخوێنەرەوە — زۆربەی خوێنەرانی کوردی
        لە عێراقدا توانای خوێندنەوەی عەرەبیشیان هەیە.
      </p>
      <p class="mt-4">
        <a
          href={arHref}
          class="inline-block bg-navy text-cream no-underline px-5 py-2.5 font-bold text-base hover:bg-magenta transition-colors"
        >
          ← خوێندنەوەی نوسخەی عەرەبی
        </a>
      </p>
    </div>

    <p class="text-sm text-muted">
      ئەگەر دەتەوێت لە وەرگێڕانەکاندا یارمەتیمان بدەی، تکایە لە ڕێگەی
      <a href="/ckb/feedback">پەڕەی تێبینی</a>وە پەیوەندیمان پێوەبکە.
    </p>
  </section>
</BaseLayout>

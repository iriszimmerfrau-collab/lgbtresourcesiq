---
import type { Lang } from '@i18n/languages';
import { t } from '@i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const label = t(lang, 'quickexit.label');
const ariaLabel = t(lang, 'quickexit.aria');
---

<!-- Noscript fallback: always-visible plain link -->
<noscript>
  <style>
    .qe-noscript {
      position: fixed;
      top: 16px;
      right: 16px;
      z-index: 999999;
      background: #c4382b;
      color: #fff;
      padding: 10px 20px;
      font-weight: 700;
      font-size: 0.875rem;
      text-decoration: none;
      line-height: 1;
    }
    .qe-noscript:hover { background: #a03020; }
  </style>
  <a href="https://www.google.com" class="qe-noscript" rel="noopener noreferrer">
    {label}
  </a>
</noscript>

<!-- JS-enhanced button (hidden until JS runs) -->
<div id="qe-container" style="display:none;">
  <!-- Desktop: top-right rectangle -->
  <button
    id="qe-desktop"
    type="button"
    aria-label={ariaLabel}
    style="position:fixed;top:16px;right:16px;z-index:999999;background:#c4382b;color:#fff;border:none;cursor:pointer;padding:10px 20px;font-weight:700;font-size:0.875rem;line-height:1;letter-spacing:0.02em;"
  >
    {label}
  </button>
  <!-- Mobile: bottom-right circle -->
  <button
    id="qe-mobile"
    type="button"
    aria-label={ariaLabel}
    style="position:fixed;bottom:24px;right:24px;z-index:999999;background:#c4382b;color:#fff;border:none;cursor:pointer;width:56px;height:56px;border-radius:50%;font-size:1.5rem;font-weight:700;line-height:1;display:none;"
  >
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true" style="display:inline-block;vertical-align:middle;">
      <path d="M15 5L10 10M10 10L5 15M10 10L15 15M10 10L5 5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
    </svg>
  </button>
</div>

<!-- White cover div (hidden until exit triggers) -->
<div id="qe-cover" style="position:fixed;inset:0;background:#fff;z-index:999999;display:none;" aria-hidden="true"></div>

<!-- Exit logic: inlined for maximum reliability, zero dependencies -->
<script is:inline>
(function() {
  var DECOY = 'https://www.google.com';
  var container = document.getElementById('qe-container');
  var cover = document.getElementById('qe-cover');
  var btnDesktop = document.getElementById('qe-desktop');
  var btnMobile = document.getElementById('qe-mobile');

  // Show JS-enhanced buttons, apply responsive visibility
  if (container) {
    container.style.display = 'block';
    function applyResponsive() {
      var w = window.innerWidth;
      if (btnDesktop) btnDesktop.style.display = w >= 768 ? 'block' : 'none';
      if (btnMobile) btnMobile.style.display = w < 768 ? 'flex' : 'none';
      if (btnMobile) {
        btnMobile.style.alignItems = 'center';
        btnMobile.style.justifyContent = 'center';
      }
    }
    applyResponsive();
    window.addEventListener('resize', applyResponsive);
  }

  function triggerExit() {
    // 1. White cover — immediately hide all content
    if (cover) cover.style.display = 'block';
    // 2. Open decoy in new tab
    try { window.open(DECOY, '_blank'); } catch(e) {}
    // 3. Replace current tab (removes from back button history)
    window.location.replace(DECOY);
  }

  // Button clicks
  if (btnDesktop) btnDesktop.addEventListener('click', triggerExit);
  if (btnMobile) btnMobile.addEventListener('click', triggerExit);

  // ESC key — works even when focus is inside inputs
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') triggerExit();
  });

  // Triple-spacebar within 500ms
  var spaceTimes = [];
  document.addEventListener('keydown', function(e) {
    if (e.code !== 'Space') return;
    var tag = e.target && e.target.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
    var now = Date.now();
    spaceTimes.push(now);
    var cutoff = now - 500;
    var recent = [];
    for (var i = 0; i < spaceTimes.length; i++) {
      if (spaceTimes[i] >= cutoff) recent.push(spaceTimes[i]);
    }
    spaceTimes = recent;
    if (spaceTimes.length >= 3) {
      e.preventDefault();
      triggerExit();
    }
  });
})();
</script>

---
import type { Lang } from '@i18n/languages';
import { t, localizedPath } from '@i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;

const links = [
  { key: 'nav.home' as const, path: '/' },
  { key: 'nav.about' as const, path: '/about' },
  { key: 'nav.safety' as const, path: '/safety' },
  { key: 'nav.community' as const, path: '/community' },
  { key: 'nav.guides' as const, path: '/guides' },
  { key: 'nav.stories' as const, path: '/stories' },
  { key: 'nav.news' as const, path: '/news' },
];

function isActive(linkPath: string): boolean {
  const full = localizedPath(lang, linkPath);
  if (linkPath === '/') return currentPath === full || currentPath === `${full}/`;
  return currentPath.startsWith(full);
}
---

<header class="bg-navy text-cream">
  <nav class="max-w-[1080px] mx-auto px-4 flex items-center justify-between h-14" aria-label="Main navigation">
    <a href={localizedPath(lang, '/')} class="font-heading font-bold text-cream no-underline text-base tracking-tight">
      {t(lang, 'site.name')}
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-5">
      {links.map(link => (
        <a
          href={localizedPath(lang, link.path)}
          class:list={[
            'text-sm no-underline transition-colors',
            isActive(link.path) ? 'text-white font-semibold' : 'text-cream/70 hover:text-white',
          ]}
          aria-current={isActive(link.path) ? 'page' : undefined}
        >
          {t(lang, link.key)}
        </a>
      ))}
      <LanguageSwitcher lang={lang} currentPath={currentPath} />
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      type="button"
      class="md:hidden text-cream p-2"
      aria-label={t(lang, 'nav.menu')}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M3 12h18M3 6h18M3 18h18"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu (hidden by default) -->
  <div id="mobile-menu" class="md:hidden hidden bg-navy border-t border-cream/10 px-4 pb-4">
    {links.map(link => (
      <a
        href={localizedPath(lang, link.path)}
        class:list={[
          'block py-2 text-sm no-underline transition-colors',
          isActive(link.path) ? 'text-white font-semibold' : 'text-cream/70 hover:text-white',
        ]}
        aria-current={isActive(link.path) ? 'page' : undefined}
      >
        {t(lang, link.key)}
      </a>
    ))}
    <div class="pt-2 border-t border-cream/10 mt-2">
      <LanguageSwitcher lang={lang} currentPath={currentPath} />
    </div>
  </div>
</header>

<script is:inline>
(function() {
  var btn = document.getElementById('mobile-menu-btn');
  var menu = document.getElementById('mobile-menu');
  if (!btn || !menu) return;
  btn.addEventListener('click', function() {
    var open = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', open ? 'false' : 'true');
  });
})();
</script>

---
/**
 * EditorialReview. Collective-level credibility callout shown on medical
 * guides (HRT, mental-health) where E-A-T trust signals matter most. Names
 * the *collective* and its lived-experience credentials, never individuals
 *. The threat model rules out personal bylines.
 *
 * Pair with reviewedBy + lastReviewed in the MedicalWebPage JSON-LD
 * emitted by the route template. The visible block tells human readers
 * the same story the schema tells AI engines.
 */
import type { Lang } from '@i18n/languages';

interface Props {
  /** ISO date string, e.g. '2026-04-29'. Drives the visible "last reviewed" line. */
  reviewedAt: string;
  lang: Lang;
}

const { reviewedAt, lang } = Astro.props;

const reviewedDate = new Date(reviewedAt);
const localeTag = lang === 'ar' ? 'ar-IQ' : lang === 'ckb' ? 'ckb-IQ' : 'en-US';
const formatted = reviewedDate.toLocaleDateString(localeTag, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const copy =
  lang === 'ar'
    ? {
        title: 'كيف كُتب هذا الدليل',
        body: 'كُتب وراجع هذا الدليل من قبل التجمع العراقي للتقدم الاجتماعي. وهو تجمع لاعراقيين كويريين لديهم خبرة معاشة مباشرة في الحصول على HRT من صيدليات عراقية، تشغيل فحوصاتهم الخاصة في مختبرات عراقية، والتعامل مع منظومة الرعاية الصحية العراقية. الأعضاء يشملون أشخاصاً على HRT منذ 1 إلى 5+ سنوات، تجارب توثيق العنف العائلي، وخبرات حقيقية في تخطيط السلامة الرقمية لمجتمع الميم العراقي. هذه ليست نصيحة طبية بل معلومات لتقليل الأضرار من أناس عاشوا ما يصفونه.',
        lastReviewed: 'آخر مراجعة',
      }
    : lang === 'ckb'
    ? {
        title: 'چۆن ئەم ڕێبەرە نووسراوە',
        body: 'ئەم ڕێبەرە لەلایەن کۆڕی پێشکەوتنی کۆمەڵایەتیی عێراقەوە نووسراوە و پێداچوونەوەی بۆ کراوە. کۆڕێکە لە کوێرە عێراقییەکان کە ئەزموونی ژیانیی ڕاستەوخۆیان هەیە لە بەدەستهێنانی HRT لە دەرمانخانە عێراقییەکان، ئەنجامدانی پشکنینەکانیان لە تاقیگە عێراقییەکاندا، و مامەڵە لەگەڵ سیستەمی چاودێریی تەندروستیی عێراقدا. ئەندامەکان ئەو کەسانە لەخۆ دەگرن کە لە ١ بۆ ٥+ ساڵە لەسەر HRT ـن، ئەزموونی بەڵگەنامەکردنی توندوتیژیی خێزانی، و ئەزموونی ڕاستەقینەی پلانی ئاسایشی دیجیتاڵی بۆ کۆمەڵگای کوێری عێراقی. ئەمە ڕاوێژی پزیشکی نییە، بەڵکو زانیاریی کەمکردنەوەی زیانە لە کەسانێکەوە کە بەخۆیان ژیاون بەو شتانەی وەسفیان دەکەن.',
        lastReviewed: 'دوایین پێداچوونەوە',
      }
    : {
        title: 'How this guide was written',
        body: 'This guide is written and reviewed by the Iraqi Social Progress Collective. A peer collective of queer Iraqis with direct lived experience sourcing HRT from Iraqi pharmacies, running their own labs at Iraqi private labs, and navigating the Iraqi healthcare landscape. Members include people who have been on HRT for 1 to 5+ years, people who have documented family violence patterns, and people with hands-on experience planning digital safety for the Iraqi queer community. This is not medical advice; it is harm-reduction information from people who have lived what they describe.',
        lastReviewed: 'Last reviewed',
      };
---

<aside
  class="not-prose my-8 p-5 border border-navy/15 bg-cream/40"
  role="complementary"
  aria-labelledby="editorial-review-heading"
>
  <h2
    id="editorial-review-heading"
    class="text-xs font-bold uppercase tracking-widest text-magenta mb-3"
  >
    {copy.title}
  </h2>
  <p class="text-sm text-body leading-relaxed m-0">{copy.body}</p>
  <p class="text-xs text-muted mt-3 m-0 font-mono">
    {copy.lastReviewed}: <time datetime={reviewedAt}>{formatted}</time>
  </p>
</aside>
